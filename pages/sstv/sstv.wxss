/* 页面背景色 - 静态颜色 */
page {
  background-color: #F5F6FA;
  height: 100%;
}

.container {
  min-height: 100vh;
  background: #F5F6FA;
  padding-bottom: 40rpx;
}

.hidden-canvas {
  width: 320rpx;
  height: 240rpx;
  position: absolute;
  top: -1000rpx;
  left: -1000rpx;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #FFFFFF;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.08);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 30rpx;
  color: #666666;
  border-bottom: 4rpx solid transparent;
  transition: all 0.3s;
}

.tab-item.active {
  color: #4A90D9;
  border-bottom-color: #4A90D9;
  font-weight: 600;
}

/* 上传区域 */
.upload-area {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin: 20rpx;
  border: 4rpx dashed #E0E0E0;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
  min-height: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-area:active {
  opacity: 0.8;
  border-color: #4A90D9;
}

.upload-area.has-image {
  padding:0;
  border-style: solid;
  border-color: #E0E0E0;
  overflow: visible;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  display: block;
  font-size: 32rpx;
  color: #1A1A2E;
  margin-bottom: 10rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #666666;
}

.upload-preview {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  display: block;
}

.upload-actions {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  z-index: 10;
}

.action-btn-small {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(26,26,46,0.65);
  backdrop-filter: blur(20rpx);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 2rpx solid rgba(255,255,255,0.2);
}

.action-btn-small:active {
  transform: scale(0.92);
  background: rgba(26,26,46,0.85);
  border-color: rgba(255,255,255,0.4);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.action-btn-small.reselect:active {
  background: rgba(74,144,217,0.8);
  border-color: rgba(74,144,217,0.6);
}

.action-btn-small.remove:active {
  background: rgba(255,107,107,0.9);
  border-color: rgba(255,107,107,0.7);
}

.action-icon {
  font-size: 36rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}

.action-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.95);
  font-weight: 500;
  letter-spacing: 2rpx;
  text-shadow: 0 1rpx 2rpx rgba(26,26,46,0.5);
}

.action-btn-small.reselect {
  background: rgba(74,144,217,0.75);
  border-color: rgba(74,144,217,0.5);
}

.action-btn-small.reselect .action-label {
  color: #FFFFFF;
}

.action-btn-small.remove {
  background: rgba(255,107,107,0.75);
  border-color: rgba(255,107,107,0.5);
}

.action-btn-small.remove .action-label {
  color: #FFFFFF;
}

.image-size-label {
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(26,26,46,0.6);
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
}

/* 按钮 */
.control-group {
  padding: 0 20rpx;
  display: flex;
  justify-content: center;
}

.action-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 按钮主题色 - 静态颜色（独立分包无法使用主包主题） */
.action-btn.primary {
  background: linear-gradient(135deg, #4A90D9, #6CB4EE) !important;
  color: #FFFFFF !important;
  opacity: 1;
}

.action-btn.btn-disabled {
  background: #E0E0E0 !important;
  color: #999999 !important;
  opacity: 0.6;
}

.action-btn.danger {
  background: linear-gradient(135deg, #FF6B6B, #FF8A80) !important;
  color: #FFFFFF !important;
}

.action-btn.secondary {
  background: #F5F6FA;
  color: #1A1A2E;
}

.action-btn:active {
  opacity: 0.9;
}

.action-btn[disabled] {
  background: #E0E0E0;
  color: #999999;
}

/* 重置 button 标签的默认样式 */
button.action-btn {
  border: none !important;
  outline: none !important;
  margin: 0 !important;
  padding: 0 !important;
  border-radius: 16rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  line-height: 88rpx !important;
  height: 88rpx !important;
  min-height: 88rpx !important;
  text-align: center !important;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08) !important;
  transition: all 0.3s !important;
}

button.action-btn::after {
  border: none !important;
}

/* 设置区域 */
.encode-settings, .decode-settings {
  padding: 20rpx;
  background: #FFFFFF;
  margin: 20rpx;
  border-radius: 16rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.setting-label {
  font-size: 28rpx;
  color: #1A1A2E;
  width: 140rpx;
}

.setting-slider {
  flex: 1;
}

.setting-value {
  font-size: 26rpx;
  color: #4A90D9;
  width: 80rpx;
  text-align: right;
}

/* 解码状态 */
.decode-status {
  text-align: center;
  padding: 40rpx 20rpx;
}

.status-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #F5F5F5;
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.status-circle.active {
  background: linear-gradient(135deg, #5BA3E6, #82B1FF);
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.status-icon {
  font-size: 60rpx;
}

.status-text {
  display: block;
  font-size: 32rpx;
  color: #1A1A2E;
  margin-bottom: 10rpx;
}

.status-hint {
  font-size: 24rpx;
  color: #666666;
}

.decode-controls {
  padding: 0 20rpx;
  display: flex;
  justify-content: center;
}

/* 解码预览 */
.decode-preview {
  background: #FFFFFF;
  margin: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  text-align: center;
}

.preview-header {
  margin-bottom: 15rpx;
}

.preview-title {
  font-size: 26rpx;
  color: #1A1A2E;
  font-weight: 600;
}

.preview-canvas {
  border-radius: 12rpx;
  background: #FFFFFF;
  display: block;
  margin: 0 auto;
}

.preview-info {
  margin-top: 15rpx;
  font-size: 24rpx;
  color: #666666;
}

/* 解码进度 */
.decode-progress {
  padding: 20rpx;
  background: #FFFFFF;
  margin: 20rpx;
  border-radius: 16rpx;
}

.progress-info {
  margin-bottom: 15rpx;
  text-align: center;
}

.progress-scan-line {
  font-size: 28rpx;
  color: #4A90D9;
  font-weight: 600;
}

.progress-bar {
  height: 20rpx;
  background: #F5F6FA;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #5BA3E6, #6CB4EE);
  transition: width 0.3s;
}

.progress-text {
  font-size: 26rpx;
  color: #666666;
  text-align: center;
}

/* 结果图片 */
.result-image-container {
  padding: 20rpx;
  background: #FFFFFF;
  margin: 20rpx;
  border-radius: 16rpx;
}

.result-label {
  display: block;
  font-size: 28rpx;
  color: #1A1A2E;
  margin-bottom: 15rpx;
}

.result-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.result-actions {
  display: flex;
  gap: 20rpx;
}

.result-actions .action-btn {
  flex: 1;
}

/* 提示 */
.tips {
  padding: 20rpx;
  background: #D1ECF1;
  margin: 20rpx;
  border-radius: 16rpx;
  border-left: 6rpx solid #17A2B8;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  color: #17A2B8;
  font-weight: 600;
  margin-bottom: 15rpx;
}

.tips-content text {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}

/* 开源项目致谢 */
.acknowledgment {
  padding: 20rpx;
  background: #FFFFFF;
  margin: 20rpx;
  border-radius: 16rpx;
  border-left: 6rpx solid #4A90D9;
}

.ack-title {
  display: block;
  font-size: 28rpx;
  color: #4A90D9;
  font-weight: 600;
  margin-bottom: 15rpx;
}

.ack-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ack-item {
  display: block;
  font-size: 24rpx;
  color: #1A1A2E;
  line-height: 1.6;
}

.ack-link {
  display: block;
  font-size: 22rpx;
  color: #4A90D9;
  line-height: 1.6;
  padding-left: 20rpx;
  word-break: break-all;
}

/* 新音频面板样式 */
.audio-panel {
  background: #FFFFFF;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.audio-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.audio-header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.audio-download-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(74,144,217,0.15);
  border: 2rpx solid rgba(74,144,217,0.3);
  transition: all 0.3s;
}

.audio-download-btn:active {
  background: rgba(74,144,217,0.3);
  transform: scale(0.95);
  border-color: rgba(74,144,217,0.6);
}

.download-icon {
  font-size: 28rpx;
  line-height: 1;
}

.download-text {
  font-size: 22rpx;
  color: rgb(74,144,217);
  font-weight: 500;
}

.audio-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.audio-format {
  font-size: 22rpx;
  color: #666666;
  background: #F5F6FA;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.audio-progress-container {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.audio-time {
  font-size: 22rpx;
  color: #666666;
  font-family: ui-monospace, SFMono-Regular, monospace;
  min-width: 60rpx;
  text-align: center;
}

.audio-progress-bar {
  flex: 1;
  height: 8rpx;
  background: #F5F6FA;
  border-radius: 4rpx;
  overflow: hidden;
}

.audio-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90D9, #B388FF);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.audio-controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.audio-play-btn {
  width: 96rpx !important;
  height: 96rpx !important;
  border-radius: 50% !important;
  background: linear-gradient(135deg, #4A90D9, #B388FF) !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  border: none !important;
  padding: 0 !important;
  line-height: 1 !important;
  margin: 0 !important;
  min-height: 96rpx !important;
}

.audio-play-btn.playing {
  background: linear-gradient(135deg, #FF6B6B, #FF8A80) !important;
}

.audio-play-btn::after {
  border: none !important;
  display: none !important;
}

.play-icon {
  font-size: 36rpx;
  color: #FFFFFF;
}

.audio-info-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.info-tag {
  font-size: 20rpx;
  color: #4A90D9;
  background: #E3F2FD;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

/* 图片容器 - 相对定位用于呼号绝对定位 */
.image-container {
  position: relative;
  width: 320px;
  height: 240px;
  overflow: visible;
  margin: 0 auto;  /* 居中显示 */
}

/* 呼号覆盖层 - 可拖动 */
.callsign-overlay {
  position: absolute;
  z-index: 999;
  padding: 8rpx 16rpx;
  background: rgba(26,26,46,0.7);
  border-radius: 8rpx;
  display: none;
  cursor: move;
  user-select: none;
  pointer-events: auto;
  /* 位置由 wxml 中的 style 动态控制，不要在这里固定 */
  top: auto;
  right: auto;
}

.callsign-overlay.show {
  display: block !important;
}

.callsign-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
  text-shadow: 2rpx 2rpx 4rpx rgba(26,26,46,0.8);
  font-family: monospace;
  white-space: nowrap;
}



/* 呼号按钮样式 */
.callsign-btn {
  background: #E3F2FD !important;
  border: 2rpx solid #4A90D9 !important;
}

.callsign-btn .action-icon,
.callsign-btn .action-label {
  color: #4A90D9 !important;
}
