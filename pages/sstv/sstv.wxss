.container {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: 40rpx;
}

.hidden-canvas {
  width: 320rpx;
  height: 240rpx;
  position: absolute;
  top: -1000rpx;
  left: -1000rpx;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: var(--card-bg);
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx var(--shadow-color);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 30rpx;
  color: var(--text-secondary);
  border-bottom: 4rpx solid transparent;
  transition: all 0.3s;
}

.tab-item.active {
  color: var(--accent-primary);
  border-bottom-color: var(--accent-primary);
  font-weight: 600;
}

/* 上传区域 */
.upload-area {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin: 20rpx;
  border: 4rpx dashed var(--border-color);
  transition: all 0.3s;
}

.upload-area:active {
  opacity: 0.8;
  border-color: var(--accent-primary);
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  display: block;
  font-size: 32rpx;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.preview-image {
  width: 90%;
  max-height: 400rpx;
  margin: 20rpx auto;
  display: block;
  border-radius: 16rpx;
}

.image-info {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
}

/* 按钮 */
.control-group {
  padding: 0 20rpx;
}

.action-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.primary {
  background: linear-gradient(135deg, var(--accent-primary), #A85540);
  color: var(--text-inverse);
}

.action-btn.danger {
  background: linear-gradient(135deg, var(--error), #A55555);
  color: var(--text-inverse);
}

.action-btn.secondary {
  background: var(--bg-primary);
  color: var(--text-primary);
}

.action-btn:active {
  opacity: 0.9;
}

.action-btn[disabled] {
  background: var(--border-color);
  color: var(--text-placeholder);
}

/* 音频播放器 */
.audio-player {
  padding: 20rpx;
  background: var(--card-bg);
  margin: 20rpx;
  border-radius: 16rpx;
}

.audio-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

/* 设置区域 */
.encode-settings, .decode-settings {
  padding: 20rpx;
  background: var(--card-bg);
  margin: 20rpx;
  border-radius: 16rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.setting-label {
  font-size: 28rpx;
  color: var(--text-primary);
  width: 140rpx;
}

.setting-slider {
  flex: 1;
}

.setting-value {
  font-size: 26rpx;
  color: var(--accent-primary);
  width: 80rpx;
  text-align: right;
}

/* 解码状态 */
.decode-status {
  text-align: center;
  padding: 40rpx 20rpx;
}

.status-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--color-log);
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.status-circle.active {
  background: linear-gradient(135deg, var(--accent-active), #6B9A5F);
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.status-icon {
  font-size: 60rpx;
}

.status-text {
  display: block;
  font-size: 32rpx;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.status-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.decode-controls {
  padding: 0 20rpx;
}

/* 解码预览 */
.decode-preview {
  background: var(--card-bg);
  margin: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  text-align: center;
}

.preview-header {
  margin-bottom: 15rpx;
}

.preview-title {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.preview-canvas {
  border-radius: 12rpx;
  background: var(--text-primary);
  display: block;
  margin: 0 auto;
}

.preview-info {
  margin-top: 15rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 解码进度 */
.decode-progress {
  padding: 20rpx;
  background: var(--card-bg);
  margin: 20rpx;
  border-radius: 16rpx;
}

.progress-bar {
  height: 20rpx;
  background: var(--bg-primary);
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent-active), var(--accent-secondary));
  transition: width 0.3s;
}

.progress-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
}

/* 结果图片 */
.result-image-container {
  padding: 20rpx;
  background: var(--card-bg);
  margin: 20rpx;
  border-radius: 16rpx;
}

.result-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 15rpx;
}

.result-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.result-actions {
  display: flex;
  gap: 20rpx;
}

.result-actions .action-btn {
  flex: 1;
}

/* 提示 */
.tips {
  padding: 20rpx;
  background: rgba(107, 142, 174, 0.1);
  margin: 20rpx;
  border-radius: 16rpx;
  border-left: 6rpx solid var(--info);
}

.tips-title {
  display: block;
  font-size: 28rpx;
  color: var(--info);
  font-weight: 600;
  margin-bottom: 15rpx;
}

.tips-content text {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}
