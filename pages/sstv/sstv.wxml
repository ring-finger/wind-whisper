<view class="theme-wrapper theme-{{currentTheme}}">
  <view class="container">
    <canvas type="2d" id="resizeCanvas" class="hidden-canvas" style="width: 320px; height: 240px;"></canvas>
    <canvas type="2d" id="encodeCanvas" class="hidden-canvas" style="width: 320px; height: 240px;"></canvas>
    <canvas type="2d" id="tempCanvas" class="hidden-canvas" style="width: 320px; height: 240px;"></canvas>
    <canvas type="2d" id="pixelCanvas" class="hidden-canvas" style="width: 320px; height: 240px;"></canvas>

    <view class="tab-bar">
      <view class="tab-item {{currentTab === 'encode' ? 'active' : ''}}" bindtap="switchTab" data-tab="encode">
        <text>编码</text>
      </view>
      <view class="tab-item {{currentTab === 'decode' ? 'active' : ''}}" bindtap="switchTab" data-tab="decode">
        <text>解码</text>
      </view>
    </view>

    <!-- 编码界面 -->
    <view class="encode-panel" wx:if="{{currentTab === 'encode'}}">
      <!-- 未选择图片时显示上传区域 -->
      <view class="upload-area" wx:if="{{!uploadImage}}" bindtap="chooseImage">
        <view class="upload-icon">📷</view>
        <text class="upload-text">点击上传图片</text>
        <text class="upload-hint">支持拍照或从相册选择</text>
      </view>
      
      <!-- 选择图片后显示图片和操作按钮 -->
      <view class="upload-area has-image" wx:else>
        <view class="image-container">
          <image class="upload-preview" src="{{uploadImage}}" mode="aspectFit" />
          <!-- 可拖动的呼号文字 -->
          <view 
            class="callsign-overlay {{showCallsign ? 'show' : ''}}"
            style="left: {{callsignX}}px; bottom: {{240 - callsignY}}px;"
            catchtouchstart="onCallsignTouchStart"
            catchtouchmove="onCallsignTouchMove"
          >
            <text class="callsign-text">{{callsign}}</text>
          </view>
        </view>
        <view class="upload-actions">
          <view class="action-btn-small reselect" catchtap="chooseImage" data-action="reselect">
            <text class="action-icon">📷</text>
            <text class="action-label">更换</text>
          </view>
          <view class="action-btn-small remove" catchtap="removeImage">
            <text class="action-icon">🗑️</text>
            <text class="action-label">删除</text>
          </view>
          <view class="action-btn-small callsign-btn" catchtap="toggleCallsignInput">
            <text class="action-icon">📻</text>
            <text class="action-label">{{showCallsign ? '隐藏' : '呼号'}}</text>
          </view>
        </view>
        <view class="image-size-label">
          <text>{{imageWidth}} x {{imageHeight}}</text>
        </view>
      </view>

      <view class="control-group">
        <button class="action-btn {{uploadImage && !isEncoding ? 'primary' : 'btn-disabled'}}" bindtap="onEncodeTap">
          {{isEncoding ? '正在生成音频...' : '生成SSTV音频'}}
        </button>
      </view>

      <view class="audio-panel" wx:if="{{audioFilePath}}">
        <view class="audio-header">
          <text class="audio-title">🎵 生成的音频</text>
          <view class="audio-header-right">
            <text class="audio-format">{{audioFormat}} · {{audioFileSize}}</text>
            <view class="audio-download-btn" catchtap="downloadAudio">
              <text class="download-icon">💾</text>
              <text class="download-text">保存</text>
            </view>
          </view>
        </view>
        
        <view class="audio-progress-container">
          <text class="audio-time">{{audioCurrentTimeStr}}</text>
          <view class="audio-progress-bar">
            <view class="audio-progress-fill" style="{{'width:' + audioProgress + '%;'}}"></view>
          </view>
          <text class="audio-time">{{audioDurationStr}}</text>
        </view>
        
        <view class="audio-controls">
          <button class="audio-play-btn {{isPlaying ? 'playing' : ''}}" bindtap="togglePlayAudio">
            <text class="play-icon">{{isPlaying ? '⏸' : '▶️'}}</text>
          </button>
          <view class="audio-info-tags">
            <text class="info-tag">Robot36</text>
            <text class="info-tag">8kHz</text>
            <text class="info-tag">单声道</text>
          </view>
        </view>
      </view>

      <view class="encode-settings">
        <view class="setting-item">
          <text class="setting-label">图片质量:</text>
          <slider class="setting-slider" min="1" max="100" value="{{quality}}" bindchange="onQualityChange" />
          <text class="setting-value">{{quality}}%</text>
        </view>
      </view>
    </view>

    <!-- 解码界面 -->
    <view class="decode-panel" wx:if="{{currentTab === 'decode'}}">
      <view class="decode-status">
        <view class="status-circle {{isDecoding ? 'active' : ''}}">
          <text class="status-icon">{{isDecoding ? '🎤' : '⏹️'}}</text>
        </view>
        <text class="status-text">{{isDecoding ? '正在监听...' : '点击开始监听'}}</text>
        <text class="status-hint" wx:if="{{isDecoding}}">请将音频源靠近麦克风</text>
      </view>

      <view class="decode-controls">
        <button class="action-btn {{isDecoding ? 'danger' : 'primary'}}" bindtap="toggleDecode">
          {{isDecoding ? '停止监听' : '开始监听'}}
        </button>
      </view>

      <!-- 解码进度 -->
      <view class="decode-progress" wx:if="{{isDecoding}}">
        <view class="progress-info">
          <text class="progress-scan-line">扫描线: {{scanLine}} / 240</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="{{'width:' + decodeProgress + '%;'}}"></view>
        </view>
        <text class="progress-text">解码进度: {{decodeProgress}}%</text>
      </view>

      <!-- 解码结果 -->
      <view class="result-image-container" wx:if="{{decodedImage}}">
        <text class="result-label">🎉 解码完成</text>
        <image class="result-image" src="{{decodedImage}}" mode="aspectFit" />
        <view class="result-actions">
          <button class="action-btn primary" bindtap="saveToAlbum">保存到相册</button>
          <button class="action-btn secondary" bindtap="clearResult">删除</button>
        </view>
      </view>

      <view class="decode-settings">
        <view class="setting-item">
          <text class="setting-label">灵敏度:</text>
          <slider class="setting-slider" min="10" max="100" value="{{sensitivity}}" bindchange="onSensitivityChange" />
          <text class="setting-value">{{sensitivity}}%</text>
        </view>
      </view>
    </view>

    <!-- 提示信息 -->
    <view class="tips">
      <text class="tips-title">💡 使用提示</text>
      <view class="tips-content" wx:if="{{currentTab === 'encode'}}">
        <text>1. 点击上传区域选择图片</text>
        <text>2. 图片会被自动调整为SSTV格式</text>
        <text>3. 调整呼号位置</text>
        <text>4. 点击生成按钮创建音频</text>
        <text>5. 通过无线电发射音频信号</text>
      </view>
      <view class="tips-content" wx:if="{{currentTab === 'decode'}}">
        <text>1. 确保环境安静，减少背景噪音</text>
        <text>2. 将音频源靠近手机麦克风</text>
        <text>3. 点击开始监听按钮</text>
        <text>4. 等待解码完成后保存图片</text>
      </view>
    </view>

    <!-- 开源项目致谢 -->
    <view class="acknowledgment" wx:if="{{currentTab === 'encode'}}">
      <text class="ack-title"> 感谢开源项目</text>
      <view class="ack-content">
        <text class="ack-item">SSTVEncoder2 (olgamiller)</text>
      </view>
    </view>
    <view class="acknowledgment" wx:if="{{currentTab === 'decode'}}">
      <text class="ack-title"> 感谢开源项目</text>
      <view class="ack-content">
        <text class="ack-item">robot36 (xdsopl)</text>
      </view>
    </view>
  </view>
</view>