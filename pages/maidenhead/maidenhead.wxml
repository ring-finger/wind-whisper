<view class="theme-wrapper {{currentTheme === 'morandi' ? 'theme-morandi' : ''}}">
  <view class="maidenhead-page">

    <!-- 分享卡片 canvas（隐藏）- 使用旧版API更可靠 -->
    <canvas canvas-id="shareCanvas" class="share-canvas"></canvas>

    <!-- 全屏地图 -->
    <view class="map-container">
      <map
        id="maidenheadMap"
        class="maidenhead-map"
        latitude="{{mapLat}}"
        longitude="{{mapLng}}"
        scale="{{mapScale}}"
        show-location="{{locationReady}}"
        polygons="{{gridPolygons}}"
        bindscale="onMapScaleChange"
        bindregionchange="onMapRegionChange"
      ></map>

      <!-- 未定位遮罩 -->
      <view class="map-overlay" wx:if="{{!locationReady}}">
        <view class="overlay-card">
          <text class="overlay-icon">📍</text>
          <text class="overlay-title" wx:if="{{!locationFailed}}">正在获取位置...</text>
          <text class="overlay-title" wx:else>未授权定位</text>
          <text class="overlay-desc" wx:if="{{!locationFailed}}">请允许位置权限以自动定位</text>
          <text class="overlay-desc" wx:else>需要位置权限才能获取当前网格</text>
          <view class="btn btn-primary overlay-btn" wx:if="{{locationFailed}}" hover-class="btn-hover" bindtap="retryLocation">
            <text>重新授权定位</text>
          </view>
        </view>
      </view>

      <!-- 底部网格信息卡 -->
      <view class="grid-info-card" wx:if="{{locationReady && currGrid}}">
        <view class="grid-main" bindtap="copyMapGrid" hover-class="button-hover">
          <view class="grid-code-wrap">
            <text class="grid-code">{{currGrid}}</text>
            <text class="grid-precision-tag">{{currPrecisionName}}</text>
          </view>
          <text class="grid-copy-hint">{{mapGridCopied ? '✓ 已复制' : '点击复制网格码'}}</text>
        </view>
        <view class="grid-coords">
          <text class="coord-text">{{currLat}}°, {{currLng}}°</text>
          <view class="coord-action" bindtap="retryLocation" hover-class="button-hover">
            <text>🔄 重新定位</text>
          </view>
        </view>
        <view class="grid-tip">
          <text>缩放地图自动切换 2/4/6/8 位精度</text>
        </view>
      </view>
    </view>

  </view>
</view>
