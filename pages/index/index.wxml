<view class="theme-wrapper {{currentTheme === 'morandi' ? 'theme-morandi' : ''}}">
  <view class="page-home">
  <!-- 顶部：个人资料卡片 -->
  <view class="profile-card" hover-class="button-hover" bindtap="goToMine">
    <view class="profile-avatar">
      <image wx:if="{{userAvatarUrl}}" class="avatar-img" src="{{userAvatarUrl}}" mode="aspectFill" />
      <text wx:else class="avatar-icon">📡</text>
    </view>
    <view class="profile-info">
      <text class="profile-title">{{userNickName || '业余无线电'}}</text>
      <text class="profile-subtitle">{{userCallsign || '设置呼号'}}</text>
    </view>
    <view class="profile-badge">
      <text class="badge-text">{{stats.totalLogs || 0}} 通联</text>
    </view>
  </view>

  <!-- 统计卡片区域 -->
  <view class="stats-grid">
    <view class="stat-card" hover-class="button-hover" bindtap="goToTodayLogs">
      <text class="stat-value">{{stats.todayLogs || 0}}</text>
      <text class="stat-label">今日通联</text>
    </view>
    <view class="stat-card" hover-class="button-hover" bindtap="goToWeekLogs">
      <text class="stat-value">{{stats.weekLogs || 0}}</text>
      <text class="stat-label">本周通联</text>
    </view>
    <view class="stat-card" hover-class="button-hover" bindtap="goToMonthLogs">
      <text class="stat-value">{{stats.monthLogs || 0}}</text>
      <text class="stat-label">本月通联</text>
    </view>
    <view class="stat-card" hover-class="button-hover" bindtap="goToAllLogs">
      <text class="stat-value">{{stats.bandCount || 0}}</text>
      <text class="stat-label">频段数</text>
    </view>
  </view>

  <!-- 功能卡片区域 -->
  <view class="feature-section">
    <view class="feature-grid">
      <!-- 通联卡片 -->
      <view class="feature-card feature-qso" hover-class="button-hover" bindtap="goToQSO">
        <view class="feature-icon-wrap">
          <text class="feature-icon">📻</text>
        </view>
        <view class="feature-content">
          <text class="feature-title">通联日志</text>
          <text class="feature-desc">记录和管理通联记录</text>
        </view>
      </view>

          <!-- SSTV卡片 -->
      <view class="feature-card feature-sstv" hover-class="button-hover" bindtap="goToSSTV">
        <view class="feature-icon-wrap">
          <text class="feature-icon">🖼️</text>
        </view>
        <view class="feature-content">
          <text class="feature-title">SSTV图像传输</text>
          <text class="feature-desc">慢扫描电视编码解码</text>
        </view>
      </view>

      <!-- 梅登黑德定位卡片 -->
      <view class="feature-card feature-maidenhead" hover-class="button-hover" bindtap="goToMaidenhead">
        <view class="feature-icon-wrap">
          <text class="feature-icon">🗺️</text>
        </view>
        <view class="feature-content">
          <text class="feature-title">梅登黑德定位</text>
          <text class="feature-desc">梅登黑德定位网格位置</text>
        </view>
      </view>

      <!-- QSL卡卡片 -->
      <view class="feature-card feature-qsl" hover-class="button-hover" bindtap="goToQSL">
        <view class="feature-icon-wrap">
          <text class="feature-icon">📬</text>
        </view>
        <view class="feature-content">
          <text class="feature-title">QSL卡</text>
          <text class="feature-desc">QSL卡片简洁设计</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 通联统计区域 -->
  <view class="contact-stats-section">
    <view class="section-title">通联统计</view>

    <!-- 个人维度：近6个月柱状图 -->
    <view class="stats-panel">
      <!-- 汇总统计 -->
      <view class="personal-summary">
        <text class="summary-text">近6个月：<text class="summary-num">{{personalTotal6 || 0}}</text></text>
        <text class="summary-text">今年通联：<text class="summary-num">{{totalThisYear || 0}}</text></text>
        <text class="summary-text">总共通联：<text class="summary-num">{{totalAll || 0}}</text></text>
      </view>
      <view class="bar-panel" wx:if="{{personalTotal6 > 0}}">
        <view class="bar-title">近6个月通联趋势</view>
        <view class="bar-chart">
          <view wx:for="{{personalMonths}}" wx:key="monthKey" class="bar-col" bindtap="onBarTap" data-year="{{item.year}}" data-month="{{item.month}}" data-count="{{item.count}}">
            <view class="bar-fill" style="height: {{item.percent}}%;">
              <text class="bar-val" wx:if="{{item.count > 0}}">{{item.count}}</text>
            </view>
            <text class="bar-label">{{item.label}}</text>
          </view>
        </view>
      </view>
      <view class="stats-empty" wx:else>
        <text class="empty-icon">📡</text>
        <text class="empty-title">还没有通联记录</text>
        <text class="empty-sub">快去添加你的第一条通联吧~</text>
      </view>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-area-bottom"></view>

  <!-- 底部悬浮添加按钮 -->
  <view class="fab-container">
    <view class="fab-btn" hover-class="fab-hover" bindtap="goToAddQSO">
      <text class="fab-icon">+</text>
    </view>
  </view>
  </view>
</view>
