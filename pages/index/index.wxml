<view class="theme-wrapper {{currentTheme === 'morandi' ? 'theme-morandi' : ''}}">
  <view class="page-home">
  <!-- 顶部：个人资料卡片 -->
  <view class="profile-card" hover-class="button-hover" bindtap="goToMine">
    <view class="profile-avatar">
      <image wx:if="{{userAvatarUrl}}" class="avatar-img" src="{{userAvatarUrl}}" mode="aspectFill" />
      <text wx:else class="avatar-icon">📡</text>
    </view>
    <view class="profile-info">
      <text class="profile-title">业余无线电</text>
      <text class="profile-subtitle">{{userCallsign || '设置呼号'}}</text>
    </view>
    <view class="profile-badge">
      <text class="badge-text">{{stats.totalLogs || 0}} 通联</text>
    </view>
  </view>

  <!-- 统计卡片区域 -->
  <view class="stats-grid">
    <view class="stat-card">
      <text class="stat-value">{{stats.todayLogs || 0}}</text>
      <text class="stat-label">今日通联</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.weekLogs || 0}}</text>
      <text class="stat-label">本周通联</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.monthLogs || 0}}</text>
      <text class="stat-label">本月通联</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.bandCount || 0}}</text>
      <text class="stat-label">频段数</text>
    </view>
  </view>

  <!-- 功能卡片区域 -->
  <view class="feature-section">
    <view class="feature-grid">
      <!-- 通联卡片 -->
      <view class="feature-card feature-qso" hover-class="button-hover" bindtap="goToQSO">
        <view class="feature-icon-wrap">
          <text class="feature-icon">📻</text>
        </view>
        <view class="feature-content">
          <text class="feature-title">通联日志</text>
          <text class="feature-desc">记录和管理通联记录</text>
        </view>
      </view>

      <!-- SSTV卡片 -->
      <view class="feature-card feature-sstv" hover-class="button-hover" bindtap="goToSSTV">
        <view class="feature-icon-wrap">
          <text class="feature-icon">🖼️</text>
        </view>
        <view class="feature-content">
          <text class="feature-title">SSTV图像传输</text>
          <text class="feature-desc">慢扫描电视编码解码</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快速操作区域 -->
  <view class="quick-section">
    <view class="section-title">最近通联</view>
    <view class="recent-list" wx:if="{{recentLogs.length > 0}}">
      <view 
        wx:for="{{recentLogs}}" 
        wx:key="id"
        class="recent-item"
        hover-class="button-hover"
        bindtap="viewLogDetail"
        data-id="{{item.id}}"
      >
        <view class="recent-left">
          <text class="recent-callsign">{{item.callSign}}</text>
          <text class="recent-mode">{{item.mode}}</text>
        </view>
        <view class="recent-right">
          <text class="recent-freq font-mono">{{item.frequency}}</text>
          <text class="recent-time font-mono">{{item.btcTime || item.bjcTime}}</text>
        </view>
      </view>
    </view>
    <view class="empty-recent" wx:else>
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无通联记录</text>
      <text class="empty-hint">点击上方"通联日志"开始记录</text>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-area-bottom"></view>

  <!-- 底部悬浮添加按钮 -->
  <view class="fab-container">
    <view class="fab-btn" hover-class="fab-hover" bindtap="goToAddQSO">
      <text class="fab-icon">+</text>
    </view>
    <view class="copyright">@BA4IWA</view>
  </view>
  </view>
</view>
