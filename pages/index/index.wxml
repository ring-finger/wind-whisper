<view class="page-index">
  <view class="float-card header-card">
    <view class="header-strip">
      <view class="header-tz-btns font-mono">
        <view
          class="header-tz-btn {{currentTimeType === 'BJT' ? 'header-tz-btn-active' : ''}}"
          hover-class="button-hover"
          bindtap="setTimeType"
          data-type="BJT"
        >BJT</view>
        <view
          class="header-tz-btn {{currentTimeType === 'UTC' ? 'header-tz-btn-active' : ''}}"
          hover-class="button-hover"
          bindtap="setTimeType"
          data-type="UTC"
        >UTC</view>
      </view>
      <view class="header-datetime-row">
        <picker mode="date" value="{{currentTimeType === 'BJT' ? formData.date : formData.utcDate}}" bindchange="onDateChange">
          <view class="header-date font-mono" hover-class="button-hover">{{currentTimeType === 'BJT' ? formData.date : formData.utcDate}}</view>
        </picker>
        <picker mode="time" value="{{formData[currentTimeType === 'BJT' ? 'bjcTime' : 'utcTime']}}" bindchange="on{{currentTimeType === 'BJT' ? 'Bjc' : 'Utc'}}TimeChange">
          <view class="header-time font-mono" hover-class="button-hover">{{formData[currentTimeType === 'BJT' ? 'bjcTime' : 'utcTime']}}</view>
        </picker>
      </view>
      <view class="refresh-btn font-mono" hover-class="button-hover" bindtap="refreshTime">↻</view>
    </view>
  </view>

  <view class="float-card">
    <view class="form-label">频率 FREQUENCY</view>
    <view class="lcd-wrap">
      <input
        class="lcd-input font-mono"
        type="digit"
        value="{{formData.frequency}}"
        bindinput="onFrequencyInput"
        placeholder="0.000"
      />
      <text class="lcd-suffix font-mono">MHz</text>
    </view>
    <view wx:if="{{frequencySuggestions.length > 0}}" class="frequency-suggestions">
      <view
        wx:for="{{frequencySuggestions}}"
        wx:key="*this"
        class="suggestion-item"
        hover-class="button-hover"
        bindtap="selectFrequency"
        data-frequency="{{item}}"
      >
        {{item}} MHz
      </view>
    </view>
  </view>

  <view class="float-card">
    <view class="form-label">呼号 CALLSIGN</view>
    <input
      class="form-input font-mono callsign-input"
      value="{{formData.callSign}}"
      bindinput="onCallSignInput"
      placeholder="CALLSIGN"
      confirm-type="done"
    />
    <view wx:if="{{callSuggestions.length > 0}}" class="call-suggestions">
      <view
        wx:for="{{callSuggestions}}"
        wx:key="*this"
        class="suggestion-item"
        hover-class="button-hover"
        bindtap="selectCallSign"
        data-callsign="{{item}}"
      >
        {{item}}
      </view>
    </view>
  </view>

  <view class="float-card">
    <view class="form-label">天气 WX（可选）</view>
    <view class="weather-icons">
      <view
        wx:for="{{weatherIcons}}"
        wx:key="value"
        class="weather-icon weather-icon-real {{formData.weather === item.value ? 'selected' : ''}}"
        hover-class="button-hover"
        bindtap="selectWeather"
        data-value="{{item.value}}"
      >
        <text class="weather-emoji">{{item.emoji}}</text>
        <text class="weather-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="float-card">
    <view class="form-label">工作模式 MODE</view>
    <view class="mode-tags">
      <view
        wx:for="{{modes}}"
        wx:key="*this"
        class="mode-tag {{formData.mode === item ? 'selected' : ''}}"
        hover-class="button-hover"
        bindtap="selectMode"
        data-mode="{{item}}"
      >
        {{item}}
      </view>
    </view>
  </view>

  <view class="float-card rst-card">
    <view class="form-label">信号报告 RST</view>
    <view class="rst-gauge">
      <view class="rst-col">
        <view class="rst-col-title">己方</view>
        <view class="stepper-block">
          <view class="stepper-row">
            <view class="stepper-btn" hover-class="button-hover" bindtap="stepRst" data-type="myRst" data-field="r" data-delta="-1">−</view>
            <text class="stepper-val font-mono">{{formData.rst.myRst.r || '·'}}</text>
            <view class="stepper-btn" hover-class="button-hover" bindtap="stepRst" data-type="myRst" data-field="r" data-delta="1">+</view>
          </view>
          <text class="stepper-sub">R</text>
        </view>
        <view class="stepper-block">
          <view class="stepper-row">
            <view class="stepper-btn" hover-class="button-hover" bindtap="stepRst" data-type="myRst" data-field="s" data-delta="-1">−</view>
            <text class="stepper-val font-mono">{{formData.rst.myRst.s || '·'}}</text>
            <view class="stepper-btn" hover-class="button-hover" bindtap="stepRst" data-type="myRst" data-field="s" data-delta="1">+</view>
          </view>
          <text class="stepper-sub">S</text>
        </view>
        <block wx:if="{{isUHF}}">
          <view wx:if="{{formData.rst.myRst.r === '5' && formData.rst.myRst.s === '9'}}" class="stepper-block">
            <view class="rst-plus-toggle" hover-class="button-hover" bindtap="toggleRstPlus" data-type="myRst">
              <view class="plus-checkbox {{rstPlusSelected.myRst ? 'checked' : ''}}">
                <text class="plus-sign font-mono">59+</text>
              </view>
            </view>
            <text class="stepper-sub">T</text>
          </view>
          <view wx:else class="rst-t-placeholder"></view>
        </block>
        <view wx:elif="{{isVHF}}" class="stepper-block">
          <view class="stepper-row">
            <view class="stepper-btn" hover-class="button-hover" bindtap="stepRst" data-type="myRst" data-field="t" data-delta="-1">−</view>
            <text class="stepper-val font-mono">{{formData.rst.myRst.t || '·'}}</text>
            <view class="stepper-btn" hover-class="button-hover" bindtap="stepRst" data-type="myRst" data-field="t" data-delta="1">+</view>
          </view>
          <text class="stepper-sub">T</text>
        </view>
        <view wx:else class="stepper-block">
          <view class="stepper-row">
            <view class="stepper-btn" hover-class="button-hover" bindtap="stepRst" data-type="myRst" data-field="t" data-delta="-1">−</view>
            <text class="stepper-val font-mono">{{formData.rst.myRst.t || '·'}}</text>
            <view class="stepper-btn" hover-class="button-hover" bindtap="stepRst" data-type="myRst" data-field="t" data-delta="1">+</view>
          </view>
          <text class="stepper-sub">T</text>
        </view>
      </view>

      <view class="rst-col-divider"></view>

      <view class="rst-col">
        <view class="rst-col-title">对方</view>
        <view class="stepper-block">
          <view class="stepper-row">
            <view class="stepper-btn" hover-class="button-hover" bindtap="stepRst" data-type="theirRst" data-field="r" data-delta="-1">−</view>
            <text class="stepper-val font-mono">{{formData.rst.theirRst.r || '·'}}</text>
            <view class="stepper-btn" hover-class="button-hover" bindtap="stepRst" data-type="theirRst" data-field="r" data-delta="1">+</view>
          </view>
          <text class="stepper-sub">R</text>
        </view>
        <view class="stepper-block">
          <view class="stepper-row">
            <view class="stepper-btn" hover-class="button-hover" bindtap="stepRst" data-type="theirRst" data-field="s" data-delta="-1">−</view>
            <text class="stepper-val font-mono">{{formData.rst.theirRst.s || '·'}}</text>
            <view class="stepper-btn" hover-class="button-hover" bindtap="stepRst" data-type="theirRst" data-field="s" data-delta="1">+</view>
          </view>
          <text class="stepper-sub">S</text>
        </view>
        <block wx:if="{{isUHF}}">
          <view wx:if="{{formData.rst.theirRst.r === '5' && formData.rst.theirRst.s === '9'}}" class="stepper-block">
            <view class="rst-plus-toggle" hover-class="button-hover" bindtap="toggleRstPlus" data-type="theirRst">
              <view class="plus-checkbox {{rstPlusSelected.theirRst ? 'checked' : ''}}">
                <text class="plus-sign font-mono">59+</text>
              </view>
            </view>
            <text class="stepper-sub">T</text>
          </view>
          <view wx:else class="rst-t-placeholder"></view>
        </block>
        <view wx:elif="{{isVHF}}" class="stepper-block">
          <view class="stepper-row">
            <view class="stepper-btn" hover-class="button-hover" bindtap="stepRst" data-type="theirRst" data-field="t" data-delta="-1">−</view>
            <text class="stepper-val font-mono">{{formData.rst.theirRst.t || '·'}}</text>
            <view class="stepper-btn" hover-class="button-hover" bindtap="stepRst" data-type="theirRst" data-field="t" data-delta="1">+</view>
          </view>
          <text class="stepper-sub">T</text>
        </view>
        <view wx:else class="stepper-block">
          <view class="stepper-row">
            <view class="stepper-btn" hover-class="button-hover" bindtap="stepRst" data-type="theirRst" data-field="t" data-delta="-1">−</view>
            <text class="stepper-val font-mono">{{formData.rst.theirRst.t || '·'}}</text>
            <view class="stepper-btn" hover-class="button-hover" bindtap="stepRst" data-type="theirRst" data-field="t" data-delta="1">+</view>
          </view>
          <text class="stepper-sub">T</text>
        </view>
      </view>
    </view>
  </view>

  <view class="float-card">
    <view class="form-label">位置 QTH</view>
    <input class="form-input input-minimal" type="text" value="{{formData.qth}}" bindinput="onQthInput" placeholder="位置" />
  </view>

  <view class="float-card">
    <view class="form-label">功率 PWR (W)</view>
    <input class="form-input input-minimal font-mono" type="number" value="{{formData.power}}" bindinput="onPowerInput" placeholder="W" />
  </view>

  <view class="float-card">
    <view class="form-label">设备 EQUIPMENT</view>
    <input class="form-input input-minimal" value="{{formData.equipment}}" bindinput="onEquipmentInput" placeholder="设备" />
  </view>

  <view class="float-card">
    <view class="form-label">天线 ANTENNA</view>
    <input class="form-input input-minimal" value="{{formData.antenna}}" bindinput="onAntennaInput" placeholder="天线" />
  </view>

  <view class="float-card">
    <view class="form-label">备注 NOTES</view>
    <textarea class="form-input textarea-minimal" value="{{formData.notes}}" bindinput="onNotesInput" placeholder="备注" auto-height />
  </view>

  <view class="submit-actions">
    <button class="submit-btn" hover-class="button-hover" bindtap="submitLog">保存日志</button>
  </view>
</view>
