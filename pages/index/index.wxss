.page-home {
  min-height: 100vh;
  background: var(--bg-primary);
  padding: 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  box-sizing: border-box;
}

/* 个人资料卡片 */
.profile-card {
  display: flex;
  align-items: center;
  background: var(--color-profile);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow-color);
}

.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  background: var(--accent-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-icon {
  font-size: 48rpx;
}

.profile-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.profile-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.profile-subtitle {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Monaco, Consolas, monospace;
}

.profile-badge {
  background: var(--accent-primary);
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.badge-text {
  font-size: 24rpx;
  color: var(--text-inverse);
  font-weight: 600;
  line-height: 1;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx var(--shadow-color);
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--accent-primary);
  font-family: ui-monospace, SFMono-Regular, monospace;
  line-height: 1.2;
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

/* 功能区域 */
.feature-section {
  margin-top: 48rpx;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.feature-card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-shadow: 0 4rpx 20rpx var(--shadow-color);
  position: relative;
  overflow: hidden;
  min-height: 180rpx;
}

.feature-qso {
  background: linear-gradient(145deg, var(--color-qso) 0%, var(--card-bg) 100%);
}

.feature-sstv {
  background: linear-gradient(145deg, var(--color-decode) 0%, var(--card-bg) 100%);
}

.feature-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.feature-qso .feature-icon-wrap {
  background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
}

.feature-sstv .feature-icon-wrap {
  background: linear-gradient(135deg, var(--accent-active), var(--accent-secondary));
}

.feature-icon {
  font-size: 36rpx;
}

.feature-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.feature-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

.feature-arrow {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
}

.arrow-icon {
  font-size: 40rpx;
  color: var(--text-secondary);
  font-weight: 300;
}

/* 最近通联 */
.quick-section {
  margin-bottom: 24rpx;
}

.recent-list {
  background: var(--card-bg);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx var(--shadow-color);
}

.recent-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.recent-callsign {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--accent-primary);
  font-family: ui-monospace, SFMono-Regular, monospace;
}

.recent-mode {
  font-size: 22rpx;
  color: var(--text-secondary);
  background: var(--bg-primary);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  align-self: flex-start;
}

.recent-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.recent-freq {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.recent-time {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 空状态 */
.empty-recent {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx var(--shadow-color);
}

.empty-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  display: block;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 8rpx;
}

/* 安全区 */
.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}

/* 悬浮添加按钮 */
.fab-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(env(safe-area-inset-bottom) + 30rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 100;
}

.fab-btn {
  width: 112rpx;
  height: 112rpx;
  background: var(--accent-primary);
  border-radius: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(196, 100, 62, 0.4);
}

.fab-hover {
  opacity: 0.85;
  transform: scale(0.95);
}

.fab-icon {
  font-size: 56rpx;
  color: var(--text-inverse);
  font-weight: 300;
  line-height: 1;
}

/* 响应式适配 */
@media (min-width: 768px) {
  .page-home {
    max-width: 720px;
    margin: 0 auto;
    padding: 32rpx;
  }

  .stats-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 24rpx;
  }

  .stat-card {
    padding: 28rpx 16rpx;
  }

  .stat-value {
    font-size: 44rpx;
  }

  .feature-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 24rpx;
  }

  .feature-card {
    padding: 36rpx 32rpx;
    min-height: 200rpx;
  }

  .feature-icon-wrap {
    width: 80rpx;
    height: 80rpx;
  }

  .feature-icon {
    font-size: 40rpx;
  }

  .feature-title {
    font-size: 34rpx;
  }

  .feature-desc {
    font-size: 24rpx;
  }
}

@media (min-width: 1024px) {
  .page-home {
    max-width: 960rpx;
  }

  .profile-card {
    padding: 40rpx;
    border-radius: 28rpx;
  }

  .profile-avatar {
    width: 120rpx;
    height: 120rpx;
  }

  .avatar-icon {
    font-size: 56rpx;
  }

  .profile-subtitle {
    font-size: 48rpx;
  }
}
