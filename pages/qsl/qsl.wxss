/* ========== 页面容器 ========== */
.qsl-page {
  background: var(--bg-primary);
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ========== 顶部控制栏 ========== */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 20rpx;
  background: var(--card-bg);
  box-shadow: 0 1rpx 6rpx var(--shadow-color);
  flex-shrink: 0;
  z-index: 100;
}

.layout-switch {
  display: flex;
  background: var(--bg-primary);
  border-radius: 10rpx;
  overflow: hidden;
}

.layout-btn {
  padding: 8rpx 22rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
  transition: all 0.2s;
}
.layout-btn.active {
  background: var(--accent-primary);
  color: var(--text-inverse);
  font-weight: 600;
}

.top-bar-label {
  font-size: 24rpx;
  color: var(--text-placeholder);
  letter-spacing: 1rpx;
}

.export-entry {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 22rpx;
  background: var(--accent-primary);
  border-radius: 12rpx;
  color: var(--text-inverse);
  font-weight: 500;
  box-shadow: 0 4rpx 14rpx rgba(var(--accent-primary-rgb), 0.25);
  transition: all 0.15s;
}
.export-entry:active {
  opacity: 0.9;
  transform: scale(0.97);
}
.export-entry .export-icon {
  font-size: 26rpx;
}
.export-entry .export-text {
  font-size: 24rpx;
  font-weight: 500;
}

/* ========== 印刷提示 ========== */
.top-hint {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-placeholder);
  padding: 8rpx 12rpx;
  background: var(--card-bg);
  flex-shrink: 0;
  border-bottom: 1rpx solid var(--border-color);
}

/* 友台设计 右上角悬浮按钮 */
.friend-float-btn {
  position: fixed;
  right: 20rpx;
  top: 130rpx;
  z-index: 110;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--accent-primary);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.15s;
}

.friend-float-btn:active {
  transform: scale(0.92);
}

.friend-float-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

/* ========== 主体 ========== */
.main-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ========== 设计区域 ========== */
.design-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 8rpx 8rpx;
}

.design-scaler {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease-out;
}

.design-stage {
  position: relative;
  background: #fff;
  box-shadow: 0 4rpx 24rpx var(--shadow-color);
  border-radius: 4rpx;
  overflow: hidden;
  flex-shrink: 0;
}

/* 背景图层 */
.bg-layer {
  position: absolute;
  z-index: 2;
  opacity: 0.3;
  pointer-events: none;
}

/* 出血边距 */
.bleed-line {
  position: absolute;
  border: 2rpx dashed #ff6b6b;
  opacity: 0.4;
  pointer-events: none;
  z-index: 5;
}

/* 裁切线 */
.trim-line {
  position: absolute;
  border: 1rpx solid var(--border-color);
  opacity: 0.35;
  pointer-events: none;
  z-index: 6;
}

/* 辅助线 */
.guide-line {
  position: absolute;
  pointer-events: none;
  z-index: 10;
  opacity: 0.65;
}
.guide-line-h {
  left: 0;
  right: 0;
  height: 0;
  border-top: 2rpx dashed var(--accent-primary);
}
.guide-line-v {
  top: 0;
  bottom: 0;
  width: 0;
  border-left: 2rpx dashed var(--accent-primary);
}
.guide-center-h {
  border-top-color: var(--error);
  opacity: 0.5;
}
.guide-center-v {
  border-left-color: var(--error);
  opacity: 0.5;
}
/* 裁切线（红色虚线，不吸附） */
.guide-trim {
  border-top-color: var(--error) !important;
  border-left-color: var(--error) !important;
  opacity: 0.35;
}
/* 元素间对齐辅助线 */
.guide-element {
  border-top-color: var(--success);
  border-left-color: var(--success);
  opacity: 0.55;
}
.guide-element.guide-center-h {
  border-top-color: var(--success);
  opacity: 0.55;
}
.guide-element.guide-center-v {
  border-left-color: var(--success);
  opacity: 0.55;
}

/* ========== 元素层 ========== */
.elements-layer {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 8;
}

.elements-drag-layer {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.drag-element {
  position: absolute;
  min-width: 20rpx;
  min-height: 20rpx;
  cursor: grab;
  touch-action: none;
  overflow: visible;
}
.drag-element-text {
  display: inline-flex;
  align-items: center;
  min-width: 0;
  min-height: 0;
}
.drag-element.selected {
  outline: 3rpx solid var(--accent-primary);
  outline-offset: 2rpx;
  z-index: 20;
  border-radius: 2rpx;
}

.drag-text {
  white-space: nowrap;
  line-height: 1.3;
  user-select: none;
  display: block;
}

.drag-image {
  display: block;
  pointer-events: none;
}

.element-delete-btn {
  position: absolute;
  top: -22rpx;
  right: -22rpx;
  width: 44rpx;
  height: 44rpx;
  background: var(--error);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(var(--error-rgb), 0.35);
  z-index: 30;
}

.resize-handle {
  position: absolute;
  bottom: -16rpx;
  right: -16rpx;
  width: 36rpx;
  height: 36rpx;
  background: var(--accent-primary);
  border-radius: 6rpx;
  border: 3rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(var(--accent-primary-rgb), 0.35);
  z-index: 30;
  touch-action: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

/* ========== 侧边面板 ========== */
.side-panel {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 4rpx 16rpx;
  padding-bottom: calc(8rpx + env(safe-area-inset-bottom));
  background: var(--card-bg);
  border-top: 1rpx solid var(--border-color);
}

/* ========== 提示文字 ========== */
.design-hint {
  font-size: 20rpx;
  color: var(--text-placeholder);
  padding: 8rpx 16rpx 4rpx;
  flex-shrink: 0;
  opacity: 0.7;
  text-align: center;
}

.design-hint .bleed-note {
  display: block;
  color: var(--error);
  font-size: 18rpx;
  margin-top: 2rpx;
  opacity: 0.55;
}

/* ========== 正反面缩略图 ========== */
.thumb-strip {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 8rpx 8rpx;
  flex-shrink: 0;
}

.thumb-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  border-radius: 14rpx;
  background: var(--bg-primary);
  border: 2rpx solid transparent;
  transition: all 0.2s;
  min-width: 120rpx;
}

.thumb-card.thumb-active {
  border-color: var(--accent-primary);
  background: var(--primary-soft);
}

.thumb-mini {
  width: 56rpx;
  height: 36rpx;
  border-radius: 3rpx;
  border: 1rpx solid var(--border-color);
  background: #fafafa;
}

.thumb-mini-v {
  width: 36rpx;
  height: 56rpx;
}

.thumb-mini-front {
  background: linear-gradient(135deg, #fff 40%, rgba(var(--accent-primary-rgb), 0.08) 100%);
}

.thumb-mini-back {
  background: linear-gradient(135deg, #fff 40%, rgba(var(--accent-primary-rgb), 0.04) 100%);
}

.thumb-label {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.thumb-active .thumb-label {
  color: var(--accent-primary);
  font-weight: 600;
}

.thumb-count {
  font-size: 20rpx;
  color: var(--text-placeholder);
}

/* ========== 底部工具栏 ========== */
.bottom-toolbar {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 10rpx 8rpx;
  padding-top: 6rpx;
  width: 100%;
}

.tool-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.tool-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  font-size: 20rpx;
  color: var(--text-secondary);
  padding: 10rpx 16rpx;
  border-radius: 12rpx;
  background: var(--bg-primary);
  transition: all 0.15s;
  min-width: 90rpx;
}

.tool-btn:active {
  background: var(--primary-soft);
  color: var(--accent-primary);
}

.tool-btn .tool-icon {
  font-size: 30rpx;
}

/* 添加文字按钮 - 圆角边框+图标风格 */
.tool-btn.tool-btn-accent {
  border: 2rpx solid var(--accent-primary);
  color: var(--accent-primary);
  background: transparent;
}
.tool-btn.tool-btn-accent:active {
  background: var(--primary-soft);
}

.tool-btn.primary {
  background: var(--accent-primary);
  color: var(--text-inverse);
  box-shadow: 0 4rpx 14rpx rgba(var(--accent-primary-rgb), 0.25);
}

.tool-btn.primary:active {
  opacity: 0.9;
  background: var(--accent-primary);
}

.tool-btn.primary .tool-icon {
  font-size: 32rpx;
}

/* 禁用状态 */
.tool-btn-disabled {
  opacity: 0.4;
  pointer-events: auto; /* 保持可点击以便触发 feedback */
}
.tool-btn-disabled:active {
  background: var(--bg-primary);
  color: var(--text-secondary);
  opacity: 0.45;
}

/* 危险操作按钮 */
.tool-btn.tool-btn-danger {
  color: var(--error);
}
.tool-btn.tool-btn-danger:active {
  background: rgba(var(--error-rgb), 0.08);
  color: var(--error);
}

/* ========== 添加文字弹窗（合并自定义+预设） ========== */
.text-picker-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.text-picker {
  background: var(--card-bg);
  border-radius: 24rpx;
  width: 88vw;
  max-width: 640rpx;
  max-height: 80vh;
  overflow-y: auto;
  padding: 36rpx 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.text-picker-input {
  font-size: 32rpx !important;
  min-height: 88rpx;
  padding: 18rpx 22rpx;
}

/* 自定义文字区域（预设之后的分割区域） */
.text-picker-custom {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-color);
}

.text-picker-subtitle {
  font-size: 24rpx;
  color: var(--text-placeholder);
  margin-bottom: 12rpx;
  display: block;
}

.preset-tags {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.preset-tag {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  background: var(--bg-primary);
  border: 2rpx solid transparent;
  transition: all 0.15s;
}

.preset-tag:active {
  background: var(--primary-soft);
  border-color: var(--accent-primary);
}

.preset-tag-label {
  font-size: 22rpx;
  color: var(--text-placeholder);
}

.preset-tag-preview {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  font-family: serif;
}

/* ========== 图标选择器 ========== */
.icon-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: flex-start;
}

.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 130rpx;
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
  background: var(--bg-primary);
  border: 2rpx solid transparent;
  transition: all 0.15s;
}

.icon-item:active {
  background: var(--primary-soft);
  border-color: var(--accent-primary);
}

.icon-thumb {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 8rpx;
}

.icon-name {
  font-size: 20rpx;
  color: var(--text-secondary);
  text-align: center;
  word-break: break-all;
}

/* ========== 模板选择器 ========== */
.template-picker-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.template-picker {
  background: var(--card-bg);
  border-radius: 24rpx;
  width: 88vw;
  max-width: 640rpx;
  max-height: 80vh;
  overflow-y: auto;
  padding: 36rpx 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.template-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.template-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  background: var(--bg-primary);
  border: 2rpx solid transparent;
  transition: all 0.15s;
}

.template-item:active {
  background: var(--primary-soft);
  border-color: var(--accent-primary);
}

.template-item-disabled {
  opacity: 0.35;
  pointer-events: none;
}

.template-thumb {
  width: 120rpx;
  height: 90rpx;
  border-radius: 8rpx;
  background: var(--card-bg);
  flex-shrink: 0;
}

.template-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.template-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.template-note {
  font-size: 20rpx;
  color: var(--text-placeholder);
  line-height: 1.3;
  white-space: pre-wrap;
  word-break: break-all;
}

.template-layout {
  font-size: 22rpx;
  color: var(--text-placeholder);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: var(--card-bg);
}

/* 清除模板按钮 */
.template-item-clear {
  border: 2rpx dashed var(--border-color);
}

.template-item-clear:active {
  border-color: var(--accent-primary);
  background: var(--primary-soft);
}

.template-thumb-clear {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-primary);
  border: 2rpx dashed var(--border-color);
}

.template-item-clear:active .template-thumb-clear {
  border-color: var(--accent-primary);
}

.template-clear-icon {
  font-size: 36rpx;
  color: var(--text-placeholder);
  line-height: 1;
}

/* ========== 文本编辑弹窗 ========== */
.edit-field {
  margin-bottom: 20rpx;
}

.edit-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
  font-weight: 500;
}

.edit-input {
  width: 100%;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 18rpx 22rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  background: var(--bg-primary);
  line-height: 1.5;
  min-height: 76rpx;
}

.edit-input:focus {
  border-color: var(--accent-primary);
  background: var(--card-bg);
}

/* 文字编辑弹窗中的内容输入框 */
.edit-text-input {
  min-height: 96rpx;
  padding: 20rpx 22rpx;
  font-size: 32rpx;
}

.edit-row {
  display: flex;
  gap: 16rpx;
}

.edit-row .edit-field {
  flex: 1;
}

/* 字体选项 */
.font-options {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.font-opt {
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
  background: var(--bg-primary);
  color: var(--text-secondary);
  font-size: 24rpx;
  font-weight: 500;
  border: 2rpx solid transparent;
  transition: all 0.15s;
}

.font-opt.active {
  background: var(--primary-soft);
  border-color: var(--accent-primary);
  color: var(--accent-primary);
}

/* 颜色预设 */
.color-presets {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.color-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 3rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  transition: all 0.15s;
}

.color-dot.selected {
  border-color: var(--accent-primary);
  box-shadow: 0 2rpx 16rpx rgba(var(--accent-primary-rgb), 0.35);
  transform: scale(1.1);
}

/* side-switch 复用 */
.side-switch {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--text-primary);
}

.side-btn {
  padding: 10rpx 24rpx;
  border-radius: 10rpx;
  background: var(--bg-primary);
  color: var(--text-secondary);
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.15s;
}
.side-btn.active {
  background: var(--accent-primary);
  color: var(--text-inverse);
}

/* ========== 导出弹窗 ========== */
.export-section {
  margin-bottom: 24rpx;
}

.export-section:last-of-type {
  margin-bottom: 0;
}

.export-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.export-row {
  display: flex;
  gap: 12rpx;
}

.export-opt {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 18rpx 10rpx;
  border-radius: 14rpx;
  background: var(--bg-primary);
  border: 2rpx solid transparent;
  transition: all 0.15s;
}

.export-opt.small {
  flex: 0 0 auto;
  padding: 16rpx 32rpx;
  min-width: 80rpx;
}

.export-opt.opt-active {
  background: var(--primary-soft);
  border-color: var(--accent-primary);
}

.opt-icon {
  font-size: 36rpx;
}

.opt-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.opt-desc {
  font-size: 20rpx;
  color: var(--text-placeholder);
}

/* 隐藏导出用canvas */
.export-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
}

/* 隐藏分享用canvas */
.share-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 500px;
  height: 400px;
}

/* ========== 旧弹窗类名兼容 ========== */
.icon-picker-mask,
.edit-modal-mask,
.export-modal-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-picker,
.edit-modal,
.export-modal {
  background: var(--card-bg);
  border-radius: 24rpx;
  width: 88vw;
  max-width: 640rpx;
  max-height: 80vh;
  overflow-y: auto;
  padding: 36rpx 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.picker-title,
.edit-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 28rpx;
  text-align: center;
}

.picker-hint {
  font-size: 20rpx;
  color: var(--text-placeholder);
  text-align: center;
  margin-top: 20rpx;
  padding: 12rpx 0 0;
  border-top: 1rpx solid var(--border-color);
  opacity: 0.7;
}

.edit-actions,
.export-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.edit-actions .btn,
.export-actions .btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.edit-actions .btn-cancel,
.export-actions .btn-cancel {
  background: var(--bg-primary);
  color: var(--text-secondary);
}

.edit-actions .btn-confirm,
.export-actions .btn-confirm {
  background: var(--accent-primary);
  color: var(--text-inverse);
}

/* ========== 背景调整模式 ========== */

/* 拖拽层激活状态 */
.bg-drag-active {
  z-index: 50 !important;
}

/* 调整模式下的背景图层 */
.bg-adjusting {
  opacity: 0.55;
}

/* 背景调整工具栏 */
.bg-adjust-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 999;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.3);
}

.bg-adjust-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.bg-adjust-hint {
  color: #fff;
  font-size: 26rpx;
  opacity: 0.9;
}

.bg-adjust-scale {
  color: rgba(255,255,255,0.55);
  font-size: 22rpx;
}

.bg-adjust-actions {
  display: flex;
  gap: 14rpx;
}

.bg-adjust-reset {
  padding: 12rpx 24rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 12rpx;
  color: #fff;
  font-size: 26rpx;
}

.bg-adjust-reset:active {
  background: rgba(255,255,255,0.3);
}

.bg-adjust-done {
  padding: 12rpx 32rpx;
  background: var(--accent-primary);
  border-radius: 12rpx;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.bg-adjust-done:active {
  opacity: 0.85;
}

/* 调整背景按钮样式 */
.adjust-btn {
  border: 1rpx solid var(--accent-primary);
  border-radius: 14rpx;
}

/* ========== 图标选择器：自定义 + 按钮 ========== */
.icon-item-add {
  border: 2rpx dashed var(--border-color);
}

.icon-item-add:active {
  border-color: var(--accent-primary);
  background: var(--primary-soft);
}

.icon-add-box {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  border: 3rpx solid var(--accent-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  background: transparent;
  transition: all 0.15s;
}

.icon-item-add:active .icon-add-box {
  background: var(--primary-soft);
  border-color: var(--accent-primary);
}

.icon-add-sign {
  font-size: 48rpx;
  color: var(--accent-primary);
  font-weight: 300;
  line-height: 1;
}
