.wc-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
  background: var(--bg-primary);
}

/* 页面简介 */
.wc-intro {
  padding: 8rpx 8rpx 20rpx;
}
.wc-intro-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

/* 上方：标签筛选区 */
.wc-filter-bar {
  background: var(--card-bg);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 24rpx var(--shadow-color);
  margin-bottom: 20rpx;
  padding: 16rpx 0;
}
.wc-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 20rpx;
}
.wc-tag {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: var(--bg-primary);
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 1rpx solid var(--border-color);
  transition: all 0.2s ease;
}
.wc-tag-active {
  background: var(--accent-primary);
  color: var(--text-inverse);
  border-color: var(--accent-primary);
}
.wc-tag-name {
  line-height: 1;
}
.wc-tag-count {
  margin-left: 8rpx;
  font-size: 22rpx;
  line-height: 1;
  opacity: 0.7;
}
.wc-tag-active .wc-tag-count {
  opacity: 0.9;
}

/* 下方：卡片展示区 */
.wc-list {
  margin-bottom: 20rpx;
}
.wc-card {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 10rpx 24rpx -4rpx var(--shadow-color);
  box-sizing: border-box;
}
.wc-card-hover {
  opacity: 0.92;
  transform: scale(0.99);
}
.wc-card-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.wc-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.wc-card-title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.wc-card-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}
.wc-card-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 10rpx;
  flex-shrink: 0;
}
.wc-card-tag {
  font-size: 20rpx;
  color: var(--accent-primary);
  background: var(--primary-soft);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}
.wc-card-arrow {
  flex-shrink: 0;
  font-size: 36rpx;
  color: var(--text-secondary);
  margin-left: 16rpx;
}

.wc-foot {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 24rpx 0;
}
.wc-empty {
  padding: 100rpx 0;
}

/* 页脚：版权与联系声明 */
.wc-footer {
  margin-top: 12rpx;
  padding: 32rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  text-align: center;
}
.wc-footer-line {
  font-size: 22rpx;
  color: var(--text-secondary);
  opacity: 0.8;
}
.wc-footer-note {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-secondary);
  opacity: 0.7;
}
.wc-footer-contact {
  margin-top: 16rpx;
  padding: 0;
  background: transparent;
  line-height: normal;
}
.wc-footer-contact::after {
  border: none;
}
.wc-footer-link {
  font-size: 24rpx;
  color: var(--accent-primary);
}

/* 悬浮新增按钮 */
/* 悬浮按钮容器：纵向排列，刷新在上方、新增在下方 */
.wc-fabs {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  z-index: 50;
}
.wc-fab {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--accent-primary);
  color: var(--text-inverse);
  font-size: 56rpx;
  line-height: 96rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx var(--shadow-color);
}
.wc-fab-refresh {
  font-size: 48rpx;
}
.wc-fab-loading {
  opacity: 0.6;
  animation: wc-spin 0.8s linear infinite;
}
@keyframes wc-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 管理弹窗 */
.wc-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}
.wc-sheet {
  width: 100%;
  background: var(--card-bg);
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  max-height: 86vh;
  overflow-y: auto;
}
.wc-sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.wc-sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.wc-sheet-close {
  font-size: 36rpx;
  color: var(--text-secondary);
  padding: 0 8rpx;
}
.wc-field {
  margin-bottom: 18rpx;
}
.wc-label {
  display: block;
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}
.wc-input {
  width: 100%;
  box-sizing: border-box;
  height: 76rpx;
  line-height: 76rpx;
  background: var(--bg-primary);
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}
.wc-input::-webkit-input-placeholder {
  color: var(--text-secondary);
  opacity: 0.6;
}
.wc-sheet-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 12rpx;
}
.wc-btn {
  flex: 1;
  font-size: 30rpx;
  border-radius: 12rpx;
  padding: 18rpx 0;
  line-height: 1.4;
  border: none;
}
.wc-btn-primary {
  background: var(--accent-primary);
  color: var(--text-inverse);
}
.wc-btn-danger {
  background: transparent;
  color: #e54d42;
  border: 1rpx solid #e54d42;
}
