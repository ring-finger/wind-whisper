<view class="logs-page">
  <view class="search-immersive">
    <view class="search-inner">
      <text class="search-icon">⌕</text>
      <input
        class="search-input font-mono"
        type="text"
        placeholder="呼号 / 频率 / 模式"
        value="{{searchQuery}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearchConfirm"
      />
    </view>
    <view
      class="filter-toggle font-mono"
      hover-class="button-hover"
      bindtap="toggleSearchExpanded"
    >
      {{searchExpanded ? '收起' : '日期筛选'}}
    </view>
  </view>

  <view class="filter-panel {{searchExpanded ? 'filter-panel-open' : ''}}">
    <view class="filter-panel-inner">
      <text class="filter-bjt-hint">按 BJT 记录日期筛选，选好后点击「搜索」</text>
      <view class="filter-row">
        <text class="filter-label">从</text>
        <picker mode="date" value="{{dateFrom}}" bindchange="onDateFromChange">
          <view class="filter-picker font-mono">{{dateFrom || '不限'}}</view>
        </picker>
      </view>
      <view class="filter-row">
        <text class="filter-label">至</text>
        <picker mode="date" value="{{dateTo}}" bindchange="onDateToChange">
          <view class="filter-picker font-mono">{{dateTo || '不限'}}</view>
        </picker>
      </view>
      <view class="filter-actions">
        <button class="filter-btn filter-btn-primary" hover-class="button-hover" bindtap="onDateSearch">搜索</button>
        <button class="filter-btn filter-btn-ghost" hover-class="button-hover" bindtap="onDateReset">重置</button>
      </view>
    </view>
  </view>

  <view wx:if="{{filteredLogs.length === 0}}" class="empty-tip">暂无记录</view>

  <view
    wx:for="{{filteredLogs}}"
    wx:key="id"
    class="log-row-card"
    hover-class="button-hover"
    bindtap="openDetail"
    data-id="{{item.id}}"
  >
    <view class="log-row-left font-mono">{{item.callSign}}</view>
    <view class="log-row-mid">
      <text class="log-row-line1 font-mono">{{item.frequency}} MHz · {{item.mode}}</text>
      <text class="log-row-line2 font-mono">BJT {{item.date}} {{item.btcTime || item.bjcTime}}</text>
    </view>
    <view class="log-row-rst font-mono">{{item.rstSummary}}</view>
  </view>
</view>
