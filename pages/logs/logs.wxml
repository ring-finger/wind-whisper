<view class="theme-wrapper {{currentTheme === 'morandi' ? 'theme-morandi' : ''}}">
  <view class="logs-page">
  <!-- 隐藏的画布用于生成分享卡片 -->
  <canvas type="2d" id="shareCardCanvas" class="share-canvas" style="width:520px;height:416px;"></canvas>

  <!-- 顶部Tab切换 -->
  <view class="page-tabs">
    <view 
      class="page-tab {{currentTab === 'add' ? 'active' : ''}}"
      hover-class="button-hover"
      bindtap="switchTab"
      data-tab="add"
    >
      <text class="tab-icon">✏️</text>
      <text class="tab-text">添加</text>
    </view>
    <view 
      class="page-tab {{currentTab === 'list' ? 'active' : ''}}"
      hover-class="button-hover"
      bindtap="switchTab"
      data-tab="list"
    >
      <text class="tab-icon">📋</text>
      <text class="tab-text">列表</text>
    </view>
  </view>

  <!-- 添加通联表单 -->
  <view class="tab-panel {{currentTab === 'add' ? 'tab-panel-show' : ''}}" wx:if="{{currentTab === 'add'}}">
    <view class="float-card header-card">
      <view class="header-strip">
        <view class="header-tz-btns font-mono">
          <view
            class="header-tz-btn {{currentTimeType === 'BJT' ? 'header-tz-btn-active' : ''}}"
            hover-class="button-hover"
            bindtap="setTimeType"
            data-type="BJT"
          >BJT</view>
          <view
            class="header-tz-btn {{currentTimeType === 'UTC' ? 'header-tz-btn-active' : ''}}"
            hover-class="button-hover"
            bindtap="setTimeType"
            data-type="UTC"
          >UTC</view>
        </view>
        <view class="header-datetime-row">
          <picker mode="date" value="{{currentTimeType === 'BJT' ? formData.date : formData.utcDate}}" bindchange="onDateChange">
            <view class="header-date font-mono" hover-class="button-hover">{{currentTimeType === 'BJT' ? formData.date : formData.utcDate}}</view>
          </picker>
          <picker mode="time" value="{{formData[currentTimeType === 'BJT' ? 'bjcTime' : 'utcTime']}}" bindchange="on{{currentTimeType === 'BJT' ? 'Bjc' : 'Utc'}}TimeChange">
            <view class="header-time font-mono" hover-class="button-hover">{{formData[currentTimeType === 'BJT' ? 'bjcTime' : 'utcTime']}}</view>
          </picker>
        </view>
        <view class="refresh-btn font-mono" hover-class="button-hover" bindtap="refreshTime">↻</view>
      </view>
    </view>

    <view class="float-card">
      <view class="form-label">频率 FREQUENCY</view>
      <view class="lcd-wrap">
        <input class="lcd-input font-mono" type="digit" value="{{formData.frequency}}" bindinput="onFrequencyInput" bindfocus="onFrequencyFocus" placeholder="0.000" />
        <text class="lcd-suffix font-mono">MHz</text>
      </view>
      <view wx:if="{{frequencySuggestions.length > 0}}" class="frequency-suggestions">
        <view wx:for="{{frequencySuggestions}}" wx:key="*this" class="suggestion-item" hover-class="button-hover" bindtap="selectFrequency" data-frequency="{{item}}">{{item}} MHz</view>
      </view>
    </view>

    <view class="float-card">
      <view class="form-label">呼号 CALLSIGN</view>
      <input class="form-input font-mono callsign-input" value="{{formData.callSign}}" bindinput="onCallSignInput" placeholder="CALLSIGN" confirm-type="done" />
      <view wx:if="{{callSuggestions.length > 0}}" class="call-suggestions">
        <view wx:for="{{callSuggestions}}" wx:key="*this" class="suggestion-item" hover-class="button-hover" bindtap="selectCallSign" data-callsign="{{item}}">{{item}}</view>
      </view>
    </view>

    <view class="float-card">
      <view class="form-label">天气 WX（可选）</view>
      <view class="weather-icons">
        <view wx:for="{{weatherIcons}}" wx:key="value" class="weather-icon weather-icon-real {{formData.weather === item.value ? 'selected' : ''}}" hover-class="button-hover" bindtap="selectWeather" data-value="{{item.value}}">
          <text class="weather-emoji">{{item.emoji}}</text>
          <text class="weather-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="float-card">
      <view class="form-label">工作模式 MODE</view>
      <view class="mode-tags">
        <view wx:for="{{modes}}" wx:key="*this" class="mode-tag {{formData.mode === item ? 'selected' : ''}}" hover-class="button-hover" bindtap="selectMode" data-mode="{{item}}">{{item}}</view>
      </view>
    </view>



    <view class="float-card">
      <view class="form-label">信号报告 RST</view>
      <view class="rst-inputs-row">
        <!-- 对方RST -->
        <view class="rst-group">
          <text class="rst-group-label">对方</text>
          <view class="rst-inputs">
            <!-- R输入框 -->
            <view class="rst-input-wrapper">
              <input 
                type="number" 
                class="rst-input font-mono" 
                maxlength="1" 
                value="{{formData.rst.theirRst.r}}" 
                placeholder="R"
                bindinput="onRstInput"
                focus="{{rstFocus.theirRst.r}}"
                data-type="theirRst" 
                data-field="r"
                id="theirRst-r"
              />
            </view>
            <!-- S输入框 -->
            <view class="rst-input-wrapper">
              <input 
                type="number" 
                class="rst-input font-mono" 
                maxlength="1" 
                value="{{formData.rst.theirRst.s}}" 
                placeholder="S"
                bindinput="onRstInput"
                focus="{{rstFocus.theirRst.s}}"
                data-type="theirRst" 
                data-field="s"
                id="theirRst-s"
              />
            </view>
            <!-- T输入框 - VHF/UHF显示+号按钮，可切换选中状态 -->
            <view class="rst-input-wrapper">
              <view wx:if="{{isVHF || isUHF}}" class="rst-input rst-plus-btn {{formData.rst.theirRst.t ? 'rst-plus-selected' : ''}}" bindtap="setRstPlus" data-type="theirRst">+</view>
              <input wx:else type="number" class="rst-input font-mono" maxlength="1" value="{{formData.rst.theirRst.t}}" placeholder="T" bindinput="onRstInput" focus="{{rstFocus.theirRst.t}}" data-type="theirRst" data-field="t" id="theirRst-t" />
            </view>
          </view>
        </view>
        <!-- 己方RST -->
        <view class="rst-group">
          <text class="rst-group-label">己方</text>
          <view class="rst-inputs">
            <!-- R输入框 -->
            <view class="rst-input-wrapper">
              <input 
                type="number" 
                class="rst-input font-mono" 
                maxlength="1" 
                value="{{formData.rst.myRst.r}}" 
                placeholder="R"
                bindinput="onRstInput"
                focus="{{rstFocus.myRst.r}}"
                data-type="myRst" 
                data-field="r"
                id="myRst-r"
              />
            </view>
            <!-- S输入框 -->
            <view class="rst-input-wrapper">
              <input 
                type="number" 
                class="rst-input font-mono" 
                maxlength="1" 
                value="{{formData.rst.myRst.s}}" 
                placeholder="S"
                bindinput="onRstInput"
                focus="{{rstFocus.myRst.s}}"
                data-type="myRst" 
                data-field="s"
                id="myRst-s"
              />
            </view>
            <!-- T输入框 - VHF/UHF显示+号按钮，可切换选中状态 -->
            <view class="rst-input-wrapper">
              <view wx:if="{{isVHF || isUHF}}" class="rst-input rst-plus-btn {{formData.rst.myRst.t ? 'rst-plus-selected' : ''}}" bindtap="setRstPlus" data-type="myRst">+</view>
              <input wx:else type="number" class="rst-input font-mono" maxlength="1" value="{{formData.rst.myRst.t}}" placeholder="T" bindinput="onRstInput" focus="{{rstFocus.myRst.t}}" data-type="myRst" data-field="t" id="myRst-t" />
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="float-card">
      <view class="form-label">位置 QTH</view>
      <input class="form-input input-minimal" type="text" value="{{formData.qth}}" bindinput="onQthInput" placeholder="位置" />
    </view>

    <view class="float-card">
      <view class="form-label">功率 PWR (W)</view>
      <view class="power-input-row">
        <input class="form-input input-minimal font-mono power-input" type="text" value="{{formData.power}}" bindinput="onPowerInput" placeholder="W" />
        <view class="power-quick-btns">
          <view class="power-quick-btn" hover-class="button-hover" bindtap="selectPower" data-power="低">低</view>
          <view class="power-quick-btn" hover-class="button-hover" bindtap="selectPower" data-power="中">中</view>
          <view class="power-quick-btn" hover-class="button-hover" bindtap="selectPower" data-power="高">高</view>
          <view class="power-quick-btn" hover-class="button-hover" bindtap="selectPower" data-power="5">5</view>
          <view class="power-quick-btn" hover-class="button-hover" bindtap="selectPower" data-power="10">10</view>
        </view>
      </view>
    </view>

    <view class="float-card">
      <view class="form-label">设备 EQUIPMENT</view>
      <input class="form-input input-minimal" value="{{formData.equipment}}" bindinput="onEquipmentInput" placeholder="设备" />
    </view>

    <view class="float-card">
      <view class="form-label">天线 ANTENNA</view>
      <input class="form-input input-minimal" value="{{formData.antenna}}" bindinput="onAntennaInput" placeholder="天线" />
    </view>

    <view class="float-card">
      <view class="form-label">备注 NOTES</view>
      <textarea class="form-input textarea-minimal" value="{{formData.notes}}" bindinput="onNotesInput" placeholder="备注" auto-height />
    </view>

    <view class="submit-actions">
      <button class="submit-btn" hover-class="button-hover" bindtap="submitLog">保存</button>
    </view>
  </view>

  <!-- 通联列表 -->
  <view class="tab-panel {{currentTab === 'list' ? 'tab-panel-show' : ''}}" wx:if="{{currentTab === 'list'}}">
    <!-- 分享操作栏 -->
    <view class="share-action-bar" wx:if="{{shareMode}}">
      <view class="share-info">
        <text class="share-tip">已选择 {{selectedLogsArray.length}} 条记录（最多10条）</text>
      </view>
      <view class="share-actions">
        <view class="share-btn-cancel" hover-class="button-hover" bindtap="cancelShare">取消</view>
        <button 
          wx:if="{{!preparingShare && !shareDataReady}}"
          class="share-btn-confirm {{selectedLogsArray.length === 0 ? 'disabled' : ''}}" 
          hover-class="button-hover"
          bindtap="prepareShareData"
        >确认分享</button>
        <button 
          wx:if="{{preparingShare}}"
          class="share-btn-confirm disabled" 
          loading="{{true}}"
        >准备中...</button>
        <button 
          wx:if="{{shareDataReady}}"
          class="share-btn-confirm" 
          open-type="share"
        >去分享</button>
      </view>
    </view>

    <!-- 正常模式搜索区域 -->
    <view wx:if="{{!shareMode}}">
      <view class="search-immersive">
        <view class="search-inner">
          <text class="search-icon">⌕</text>
          <input
            class="search-input font-mono"
            type="text"
            placeholder="呼号 / 频率 / 模式"
            value="{{searchQuery}}"
            bindinput="onSearchInput"
            confirm-type="search"
            bindconfirm="onSearchConfirm"
          />
        </view>
        <view
          class="filter-toggle font-mono"
          hover-class="button-hover"
          bindtap="toggleSearchExpanded"
        >
          {{searchExpanded ? '收起' : '日期'}}
        </view>
        <view
          class="share-toggle-btn {{showShareGuide ? 'share-guide-pulse' : ''}}"
          hover-class="button-hover"
          bindtap="enterShareMode"
          wx:if="{{filteredLogs.length > 0}}"
        >
          <view class="share-guide-ring" wx:if="{{showShareGuide}}"></view>
          <text class="share-toggle-icon">📤</text>
        </view>
      </view>

      <!-- 筛选面板 -->
      <view class="filter-panel {{searchExpanded ? 'filter-panel-open' : ''}}">
        <view class="filter-panel-inner">
          <view class="filter-row">
            <text class="filter-label">从</text>
            <picker mode="date" value="{{dateFrom}}" bindchange="onDateFromChange">
              <view class="filter-picker font-mono">{{dateFrom || '不限'}}</view>
            </picker>
            <text class="filter-label" style="margin-left: 24rpx;">至</text>
            <picker mode="date" value="{{dateTo}}" bindchange="onDateToChange">
              <view class="filter-picker font-mono">{{dateTo || '不限'}}</view>
            </picker>
          </view>
          <view class="filter-actions">
            <view class="filter-btn filter-btn-primary" hover-class="button-hover" bindtap="onDateSearch">搜索</view>
            <view class="filter-btn filter-btn-ghost" hover-class="button-hover" bindtap="onDateReset">重置</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{filteredLogs.length === 0 && !shareMode}}" class="empty-tip">暂无记录</view>

    <!-- 通联记录列表 -->
    <view
      wx:for="{{filteredLogs}}"
      wx:key="id"
      class="log-row-card {{shareMode ? 'log-row-shareable' : ''}} {{selectedLogs[item.id] ? 'log-row-selected' : ''}}"
      hover-class="{{shareMode ? '' : 'button-hover'}}"
      bindtap="{{shareMode ? 'toggleLogSelect' : 'openDetail'}}"
      data-id="{{item.id}}"
      data-shareid="{{currentShareId || ''}}"
    >
      <!-- 选择指示器 -->
      <view class="log-select-indicator" wx:if="{{shareMode}}">
        <view class="log-select-circle {{selectedLogs[item.id] ? 'log-select-circle-active' : ''}}">
          <text class="log-select-check" wx:if="{{selectedLogs[item.id]}}">✓</text>
        </view>
      </view>
      <!-- 分享来源标签 -->
      <view class="share-source-tag" wx:if="{{currentShareId && !shareMode}}">
        来自{{shareOwnerCallSign || 'TA'}}的分享
      </view>
      <view class="log-row-left font-mono">{{item.callSign}}</view>
      <view class="log-row-mid">
        <text class="log-row-line1 font-mono">{{item.frequency}} MHz · {{item.mode}}</text>
        <text class="log-row-line2 font-mono">BJT {{item.date}} {{item.btcTime || item.bjcTime}}</text>
      </view>
      <view class="log-row-rst font-mono">{{item.rstSummary}}</view>
    </view>
  </view>
  </view>

  <!-- 我的分享弹窗 -->
  <view class="modal-mask {{showMySharesModal ? 'modal-show' : ''}}" bindtap="hideMyShares"></view>
  <view class="my-shares-modal {{showMySharesModal ? 'my-shares-modal-show' : ''}}">
    <view class="my-shares-header">
      <text class="my-shares-title">我的分享</text>
      <view class="my-shares-close" bindtap="hideMyShares">✕</view>
    </view>
    <view class="my-shares-content">
      <view wx:if="{{myShareList.length === 0}}" class="my-shares-empty">
        <text>暂无分享记录</text>
      </view>
      <view wx:for="{{myShareList}}" wx:key="id" class="share-record-item">
        <view class="share-record-info">
          <text class="share-record-title">{{item.shareTitle || '通联记录分享'}}</text>
          <text class="share-record-meta">剩余 {{item.expireDaysLeft}} 天有效期</text>
        </view>
        <view class="share-record-actions">
          <view class="share-record-share" bindtap="viewShareDetail" data-id="{{item.id}}">查看详情</view>
          <view class="share-record-delete" bindtap="deleteShareRecord" data-id="{{item.id}}">删除</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 右下角悬浮分享入口 -->
  <view 
    class="float-share-btn {{showShareGuide && filteredLogs.length > 0 ? 'share-guide-pulse' : ''}}" 
    hover-class="float-share-btn-hover" 
    bindtap="showMyShares" 
    wx:if="{{!shareMode}}"
  >
    <view class="share-guide-ring" wx:if="{{showShareGuide && filteredLogs.length > 0}}"></view>
    <text class="float-share-icon">📋</text>
    <view class="float-share-badge" wx:if="{{myShareCount > 0}}">{{myShareCount > 99 ? '99+' : myShareCount}}</view>
  </view>

  <!-- 分享详情弹窗 -->
  <view class="modal-mask {{showShareDetailModal ? 'modal-show' : ''}}" bindtap="hideShareDetail"></view>
  <view class="share-detail-modal {{showShareDetailModal ? 'share-detail-modal-show' : ''}}">
    <view class="share-detail-header">
      <text class="share-detail-title">{{shareDetailData.myCallSign || 'BA4IWA'}} 的分享</text>
      <view class="share-detail-close" bindtap="hideShareDetail">✕</view>
    </view>
    <view class="share-detail-content">
      <view wx:if="{{shareDetailLoading}}" class="share-detail-loading">
        <text>加载中...</text>
      </view>
      <view wx:elif="{{shareDetailLogs.length === 0}}" class="share-detail-empty">
        <text>暂无记录</text>
      </view>
      <view wx:else class="share-detail-list">
        <view wx:for="{{shareDetailLogs}}" wx:key="index" class="share-detail-item">
          <view class="share-detail-item-header">
            <text class="share-detail-callsign font-mono">{{item.callSign}}</text>
            <text class="share-detail-freq font-mono">{{item.frequency}} MHz</text>
            <text class="share-detail-mode font-mono">{{item.mode}}</text>
          </view>
          <view class="share-detail-item-info font-mono">
            BJT {{item.date}} {{item.btcTime || item.bjcTime}}
            <text wx:if="{{item.rstSummary}}"> · {{item.rstSummary}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
