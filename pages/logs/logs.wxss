.logs-page {
  min-height: 100vh;
  background: var(--bg-primary);
}

/* Tab切换 */
.page-tabs {
  display: flex;
  background: var(--card-bg);
  padding: 8rpx;
  margin: 16rpx;
  border-radius: 16rpx;
  gap: 8rpx;
  box-shadow: 0 4rpx 16rpx var(--shadow-color);
}

.page-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  background: transparent;
  transition: all 0.2s ease;
}

.page-tab.active {
  background: var(--accent-primary);
}

.page-tab .tab-icon {
  font-size: 28rpx;
}

.page-tab .tab-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.page-tab.active .tab-text {
  color: var(--text-inverse);
}

/* Tab面板 */
.tab-panel {
  display: none;
  padding: 0 16rpx;
  padding-bottom: 32rpx;
}

.tab-panel-show {
  display: block;
}

/* 搜索区域 */
.search-immersive {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
}

.search-inner {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 4rpx 16rpx var(--shadow-color);
}

.search-icon {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  background: transparent;
  border: none;
}

.filter-toggle {
  padding: 16rpx 24rpx;
  background: var(--card-bg);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--accent-primary);
  box-shadow: 0 4rpx 16rpx var(--shadow-color);
}

.filter-panel {
  display: none;
  background: var(--card-bg);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx var(--shadow-color);
}

.filter-panel-open {
  display: block;
}

.filter-panel-inner {
  padding: 24rpx;
}

.filter-bjt-hint {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.filter-label {
  font-size: 26rpx;
  color: var(--text-primary);
  width: 40rpx;
}

.filter-picker {
  flex: 1;
  padding: 16rpx 20rpx;
  background: var(--bg-primary);
  border-radius: 10rpx;
  font-size: 26rpx;
  color: var(--text-primary);
}

.filter-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.filter-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
  border: none;
}

.filter-btn-primary {
  background: var(--accent-primary);
  color: var(--text-inverse);
}

.filter-btn-ghost {
  background: var(--bg-primary);
  color: var(--text-primary);
}

/* 日志列表 */
.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: var(--text-secondary);
  font-size: 28rpx;
}

.log-row-card {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx var(--shadow-color);
}

.log-row-left {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--accent-primary);
  min-width: 160rpx;
}

.log-row-mid {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.log-row-line1 {
  font-size: 26rpx;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.log-row-line2 {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.log-row-rst {
  font-size: 24rpx;
  color: var(--accent-orange);
  font-weight: 600;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* 添加表单样式 */
.float-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 24rpx var(--shadow-color);
  box-sizing: border-box;
}

.header-card {
  padding: 20rpx 24rpx;
}

.header-strip {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-tz-btns {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx;
  background: var(--bg-primary);
  border-radius: 12rpx;
}

.header-tz-btn {
  padding: 10rpx 22rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  background: transparent;
}

.header-tz-btn-active {
  background: var(--accent-primary);
  color: var(--text-inverse);
  font-weight: 700;
}

.header-datetime-row {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
  min-width: 0;
}

.header-date {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 1rpx;
}

.header-time {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

.refresh-btn {
  flex-shrink: 0;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-primary);
  border-radius: 12rpx;
  font-size: 30rpx;
  color: var(--accent-primary);
}

.form-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.lcd-wrap {
  display: flex;
  align-items: center;
  background: var(--lcd-bg);
  border-radius: 12rpx;
  padding: 8rpx 20rpx 8rpx 24rpx;
  box-shadow: inset 0 2rpx 8rpx rgba(180, 169, 150, 0.12);
  border: 1rpx solid var(--border-color);
}

.lcd-input {
  flex: 1;
  height: 88rpx;
  font-size: 40rpx;
  font-weight: 700;
  text-align: right;
  color: var(--text-primary);
  border: none;
  background: transparent;
}

.lcd-suffix {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-left: 12rpx;
  flex-shrink: 0;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  text-align: left;
  line-height: 76rpx;
  background: var(--card-bg);
}

.callsign-input {
  text-transform: uppercase;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.input-minimal {
  border: none;
  border-bottom: 1rpx solid var(--border-color);
  border-radius: 0;
  background: transparent;
  padding-left: 0;
  padding-right: 0;
}

.textarea-minimal {
  min-height: 160rpx;
  height: auto;
  line-height: 1.5;
  border: none;
  border-radius: 12rpx;
  background: var(--bg-primary);
  padding: 20rpx;
  box-sizing: border-box;
}

.call-suggestions,
.frequency-suggestions {
  margin-top: 12rpx;
  background: var(--card-bg);
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx var(--shadow-color);
  overflow: hidden;
}

.suggestion-item {
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid var(--border-color);
  font-size: 28rpx;
  color: var(--text-primary);
}

.suggestion-item:last-child {
  border-bottom: none;
}

.weather-icons {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.weather-icon-real {
  height: auto;
  min-height: 120rpx;
  flex-direction: column;
  padding: 12rpx 6rpx 14rpx;
  border-radius: 16rpx;
  gap: 6rpx;
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.weather-icon-real.selected {
  background: var(--primary-soft);
  box-shadow: 0 0 0 3rpx var(--accent-primary);
}

.weather-emoji {
  font-size: 52rpx;
  line-height: 1.1;
}

.weather-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.weather-icon-real.selected .weather-label {
  color: var(--accent-primary);
}

.mode-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.mode-tag {
  padding: 14rpx 28rpx;
  background: rgba(122, 111, 95, 0.12);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  border: none;
  transition: all 0.2s ease;
}

.mode-tag.selected {
  background: var(--accent-primary);
  color: var(--text-inverse);
}

.rst-inputs-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rst-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.rst-group-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.rst-inputs {
  display: flex;
  gap: 12rpx;
}

.rst-input {
  flex: 1;
  height: 80rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--accent-orange);
  background: var(--bg-primary);
  border: none;
  border-radius: 12rpx;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

.submit-actions {
  display: flex;
  justify-content: center;
  width: 100%;
  margin-top: 32rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: var(--accent-primary);
  color: var(--text-inverse);
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(196, 100, 62, 0.3);
  text-align: center;
  line-height: 88rpx;
}

.submit-btn::after {
  border: none;
}
