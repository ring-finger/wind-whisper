.container {
  padding: 24rpx;
  box-sizing: border-box;
  min-height: 100vh;
  background: var(--bg-primary);
}

.log-detail-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 24rpx var(--shadow-color);
  overflow: hidden;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 30rpx 30rpx 20rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.callsign {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--accent-primary);
}

.date {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: right;
  max-width: 100%;
  word-break: break-all;
}

.info-section {
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--accent-primary);
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.info-item {
  width: calc(50% - 10rpx);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-item-block {
  width: 100%;
}

.weather-detail-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.weather-detail-emoji {
  font-size: 44rpx;
  line-height: 1;
}

.weather-detail-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.info-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
  word-break: break-all;
}

.info-remarks {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 10rpx;
}

.rst-accent {
  color: var(--accent-orange);
  font-weight: 700;
  letter-spacing: 2rpx;
}

.log-footer {
  padding: 20rpx 30rpx;
  background: var(--bg-primary);
}

.footer-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.action-bar {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
  padding: 0 10rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-btn {
  background: var(--card-bg);
  color: var(--error);
  border: 2rpx solid var(--error);
}

.edit-btn {
  background: var(--accent-primary);
  color: var(--text-inverse);
}
