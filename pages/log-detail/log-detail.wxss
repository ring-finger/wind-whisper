.container {
  padding: 24rpx;
  box-sizing: border-box;
  background: var(--bg-primary);
  flex: 1;
  height: calc(100vh - 140rpx);
}

.theme-wrapper {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--bg-primary);
}

.log-detail-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 24rpx var(--shadow-color);
  overflow: hidden;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 12rpx;
}

.callsign {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--accent-primary);
}

.date {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: right;
  max-width: 100%;
  word-break: break-all;
}

.info-section {
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--accent-primary);
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.info-item {
  width: calc(50% - 10rpx);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-item-block {
  width: 100%;
}

.weather-detail-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.weather-detail-emoji {
  font-size: 44rpx;
  line-height: 1;
}

.weather-detail-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.info-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
  word-break: break-all;
}

.info-remarks {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 10rpx;
}

.rst-accent {
  color: var(--accent-orange);
  font-weight: 700;
  letter-spacing: 2rpx;
}

.log-footer {
  padding: 20rpx 30rpx;
  background: var(--bg-primary);
}

.footer-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--bg-primary);
  box-shadow: 0 -4rpx 24rpx var(--shadow-color);
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-btn {
  background: var(--card-bg);
  color: var(--error);
  border: 2rpx solid var(--error);
}

.edit-btn {
  background: var(--accent-primary);
  color: var(--text-inverse);
}

/* 可点击项样式 */
.copyable-item {
  border-radius: 8rpx;
  padding: 8rpx 12rpx;
  margin: -8rpx -12rpx;
  transition: background-color 0.15s ease;
}

.copyable-item-hover {
  background: var(--bg-primary) !important;
}

.copyable-header {
  padding: 30rpx 30rpx 20rpx;
  border-bottom: 1rpx solid var(--border-color);
  border-radius: 8rpx;
  transition: background-color 0.15s ease;
}

.copyable-header-hover {
  background: rgba(44, 92, 151, 0.05) !important;
}

.copy-hint {
  font-size: 22rpx;
  color: var(--text-secondary);
  opacity: 0.6;
  margin-top: 8rpx;
}

/* 复制成功提示 */
.copy-toast {
  position: fixed;
  top: 120rpx;
  left: 50%;
  transform: translateX(-50%) translateY(-20rpx);
  background: rgba(0, 0, 0, 0.75);
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  z-index: 1000;
  opacity: 0;
  transition: opacity 0.25s ease, transform 0.25s ease;
  pointer-events: none;
}

.copy-toast-show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

.copy-toast-icon {
  color: #4caf50;
  font-size: 28rpx;
  font-weight: bold;
}

.copy-toast-text {
  color: #fff;
}
