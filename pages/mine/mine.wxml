<view class="theme-wrapper {{currentTheme === 'morandi' ? 'theme-morandi' : ''}}">
  <view class="mine-page">
    <view wx:if="{{easterEggMessage}}" class="easter-egg-message">{{easterEggMessage}}</view>

    <view class="mine-card profile-row">
      <view class="avatar-stack">
        <view class="avatar-face">
          <image wx:if="{{userAvatarUrl}}" class="user-avatar-img" src="{{userAvatarUrl}}" mode="aspectFill" />
          <view wx:else class="user-avatar-placeholder" />
        </view>
        <button
          class="avatar-tap"
          open-type="chooseAvatar"
          bindchooseavatar="onChooseAvatar"
          hover-class="button-hover"
        />
      </view>
      <input
        class="nickname-input"
        type="nickname"
        value="{{userNickName}}"
        placeholder="昵称"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
      />
    </view>

    <view class="mine-card mine-group">
      <view class="cell cell-tap" hover-class="cell-hover" bindtap="editCallSign">
        <view class="cell-primary-block">
          <text class="cell-label cell-label-strong">无线电呼号</text>
        </view>
        <text class="cell-value cell-value-callsign font-mono">{{myCallSign || '未设置'}}</text>
        <text class="cell-chevron">›</text>
      </view>
      <view class="cell cell-static">
        <text class="cell-label cell-label-strong">通联记录次数</text>
        <text class="cell-value cell-value-count">{{contactCount}} 次</text>
        <text class="cell-chevron cell-chevron-placeholder" aria-hidden="true">›</text>
      </view>
    </view>

    <view class="mine-card mine-group">
      <view class="cell cell-tap" hover-class="cell-hover" bindtap="exportLogs">
        <text class="cell-label cell-label-full">导出日志</text>
        <text class="cell-chevron">›</text>
      </view>
      <view class="cell cell-tap" hover-class="cell-hover" bindtap="clearLogs">
        <text class="cell-label cell-label-full">清空日志</text>
        <text class="cell-chevron">›</text>
      </view>
    </view>

    <!-- 云同步配置 -->
    <view class="mine-card mine-group">
      <view class="section-header">
        <text class="section-title">云端同步</text>
      </view>
      <view class="cell cell-switch" hover-class="cell-hover">
        <view class="cell-primary-block">
          <text class="cell-label cell-label-strong">开启云同步</text>
        </view>
        <switch 
          checked="{{cloudSyncEnabled}}" 
          bindchange="toggleCloudSync"
          color="#e74c3c"
        />
      </view>
      <view class="cell cell-tip">
        <text class="cell-tip-text">{{cloudSyncTips}}</text>
      </view>
      <view class="cloud-sync-actions" wx:if="{{cloudSyncEnabled}}">
        <view class="cloud-action-btn" hover-class="button-hover" bindtap="syncAllLogsToCloud">
          <text class="cloud-action-icon">⬆️</text>
          <text class="cloud-action-text">同步本地到云端</text>
        </view>
        <view class="cloud-action-btn" hover-class="button-hover" bindtap="restoreFromCloud">
          <text class="cloud-action-icon">⬇️</text>
          <text class="cloud-action-text">从云端恢复</text>
        </view>
      </view>
    </view>

    <!-- 免责声明弹窗 -->
    <view class="modal-mask {{showCloudDisclaimer ? 'modal-show' : ''}}" bindtap="hideCloudDisclaimer"></view>
    <view class="cloud-disclaimer-modal {{showCloudDisclaimer ? 'cloud-disclaimer-modal-show' : ''}}">
      <view class="cloud-disclaimer-header">
        <text class="cloud-disclaimer-title">云端同步免责声明</text>
      </view>
      <view class="cloud-disclaimer-content">
        <text class="cloud-disclaimer-text">{{cloudDisclaimerText}}</text>
      </view>
      <view class="cloud-disclaimer-footer">
        <view class="cloud-disclaimer-btn cloud-disclaimer-cancel" hover-class="button-hover" bindtap="hideCloudDisclaimer">
          <text>不同意</text>
        </view>
        <view class="cloud-disclaimer-btn cloud-disclaimer-agree" hover-class="button-hover" bindtap="agreeCloudDisclaimer">
          <text>同意并开启</text>
        </view>
      </view>
    </view>

    <view class="mine-card mine-group">
      <view class="cell cell-tap" hover-class="cell-hover" bindtap="toggleTheme">
        <view class="cell-primary-block">
          <text class="cell-label cell-label-strong">主题</text>
        </view>
        <view class="theme-indicator">
          <view class="theme-dot {{currentTheme === 'radio' ? 'theme-dot-active' : ''}}" style="background: #2C5C97;"></view>
          <view class="theme-dot {{currentTheme === 'morandi' ? 'theme-dot-active' : ''}}" style="background: #C4643E;"></view>
        </view>
        <text class="cell-value">{{currentThemeName}}</text>
        <text class="cell-chevron">›</text>
      </view>
    </view>

    <view class="mine-card mine-group">
      <view class="cell cell-tap" hover-class="cell-hover" bindtap="showUpdateLogModal">
        <text class="cell-label cell-label-full">更新日志</text>
        <text class="cell-version">v{{currentVersion}}</text>
        <text class="cell-chevron">›</text>
      </view>
      <view class="cell cell-tap" hover-class="cell-hover" bindtap="toggleAuthorInfo">
        <text class="cell-label cell-label-full">联系作者</text>
        <text class="cell-chevron">›</text>
      </view>
    </view>

    <view wx:if="{{showAuthorInfo}}" class="mine-card author-card">
      <view class="author-header">
        <text class="author-label">作者</text>
        <text class="author-name font-mono easter-egg-trigger" bindtap="onAuthorTap">{{authorCallSign}}</text>
      </view>
      <view class="author-action" hover-class="button-hover" bindtap="contactAuthor">
        <text class="author-action-text">打开公众号文章</text>
        <text class="author-action-chevron">›</text>
      </view>
      <text class="author-hint">关注公众号【饮月听风】</text>
    </view>

    <!-- 更新日志弹窗 -->
    <view class="modal-mask {{showUpdateLog ? 'modal-show' : ''}}" bindtap="hideUpdateLog"></view>
    <view class="update-log-modal {{showUpdateLog ? 'update-log-modal-show' : ''}}">
      <view class="update-log-header">
        <text class="update-log-title">📋 更新日志</text>
        <view class="update-log-close" bindtap="hideUpdateLog">✕</view>
      </view>
      <scroll-view class="update-log-content" scroll-y>
        <view wx:for="{{updateLogList}}" wx:key="version" class="update-log-item">
          <view class="update-log-version">
            <text class="version-tag">v{{item.version}}</text>
            <text class="version-date">{{item.date}}</text>
          </view>
          <view class="update-log-title-text">{{item.title}}</view>
          <view class="update-log-list">
            <text wx:for="{{item.content}}" wx:for-item="line" wx:key="*this" class="update-log-line">• {{line}}</text>
          </view>
        </view>
      </scroll-view>
      <view class="update-log-footer">
        <view class="update-log-btn" hover-class="button-hover" bindtap="hideUpdateLog">
          <text>知道了</text>
        </view>
      </view>
    </view>
  </view>
</view>