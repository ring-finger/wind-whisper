/* 奶油莫兰迪主题 - 个人信息页面 */
.mine-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
  background: var(--bg-primary);
}

.mine-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 24rpx var(--shadow-color);
  margin-bottom: 20rpx;
  overflow: hidden;
}

/* 头像 + 昵称 */
.profile-row {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  gap: 28rpx;
}

.avatar-stack {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
  flex-grow: 0;
  border-radius: 50%;
  overflow: hidden;
  background: var(--bg-primary);
  box-shadow: 0 0 0 2rpx var(--primary-soft);
}

.avatar-face {
  position: absolute;
  left: 0;
  top: 0;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  pointer-events: none;
  background: var(--bg-primary);
}

.user-avatar-img {
  width: 120rpx;
  height: 120rpx;
  display: block;
}

.user-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--lcd-bg);
  border: 1rpx solid var(--border-color);
  box-sizing: border-box;
}

.avatar-tap {
  position: absolute;
  left: 0;
  top: 0;
  width: 120rpx;
  height: 120rpx;
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 50%;
  background: transparent;
  line-height: 0;
  min-height: 0;
  box-sizing: border-box;
}

.avatar-tap::after {
  border: none;
}

.nickname-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  padding: 0 20rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  background: var(--card-bg);
  border-radius: 12rpx;
  border: 1rpx solid var(--border-color);
  box-sizing: border-box;
}

/* 分组列表 */
.mine-group .cell {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 100rpx;
  padding: 20rpx 28rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid var(--border-color);
}

.mine-group .cell:last-child {
  border-bottom: none;
}

.cell-primary-block {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  max-width: 46%;
}

.cell-label-strong {
  font-weight: 600;
  color: var(--text-primary);
}

.cell-value-callsign {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: var(--accent-primary);
}

.cell-value-count {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.cell-hover {
  opacity: 0.88;
}

/* 联系客服 - 透明覆盖层方案 */
/* view 负责显示，button 铺满整个 cell 接收点击 */
.contact-cell {
  position: relative;
}

.contact-overlay {
  position: absolute;
  top: 0 !important;
  left: 0 !important;
  width: 100% !important;
  height: 100% !important;
  z-index: 5;
  margin: 0 !important;
  padding: 0 !important;
  border: none !important;
  border-radius: 0 !important;
  background: transparent !important;
  opacity: 0.01;
  min-width: 0 !important;
  min-height: 0 !important;
  font-size: 0 !important;
  line-height: 0 !important;
}

.contact-overlay::after {
  border: none !important;
}

.cell-label {
  flex-shrink: 0;
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.cell-label-full {
  flex: 1;
}

.cell-value {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: var(--text-primary);
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cell-chevron {
  flex-shrink: 0;
  font-size: 32rpx;
  color: var(--text-secondary);
  font-weight: 300;
  line-height: 1;
}

.cell-chevron-placeholder {
  opacity: 0;
  pointer-events: none;
}

.easter-egg-message {
  position: fixed;
  top: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  text-align: center;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  background: rgba(58, 50, 38, 0.9);
  border-radius: 40rpx;
  color: var(--text-inverse);
  z-index: 9999;
  white-space: nowrap;
  max-width: 90%;
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* 联系作者展开区 */
.author-card {
  padding: 32rpx 28rpx 28rpx;
}

.author-header {
  display: flex;
  align-items: baseline;
  justify-content: center;
  flex-wrap: wrap;
  gap: 8rpx 12rpx;
  margin-bottom: 28rpx;
}

.author-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.author-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--accent-primary);
  letter-spacing: 2rpx;
}

.author-action {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  padding: 22rpx 56rpx 22rpx 28rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  background: var(--lcd-bg);
  border: 1rpx solid var(--border-color);
  box-sizing: border-box;
}

.author-action-text {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--accent-primary);
}

.author-action-chevron {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  font-weight: 300;
  color: var(--accent-primary);
  line-height: 1;
}

.author-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.45;
  padding: 0 8rpx;
}

/* 主题选择器 */
.theme-indicator {
  display: flex;
  gap: 12rpx;
  margin-right: 16rpx;
}

.theme-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  opacity: 0.4;
  transition: all 0.25s ease;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
}

.theme-dot-active {
  opacity: 1;
  transform: scale(1.15);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.25);
}

/* 主题切换动画 */
.theme-wrapper {
  transition: background-color 0.3s ease, color 0.3s ease;
}

/* 云同步配置 */
.section-header {
  padding: 20rpx 28rpx 0;
}

.section-title {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.switch-chevron-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-chevron {
  transition: transform 0.2s ease;
}

.section-chevron-expanded {
  transform: rotate(90deg);
}

.cell-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.cell-tip {
  padding: 16rpx 28rpx 20rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.cell-tip-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.cloud-sync-actions {
  padding: 12rpx 20rpx 16rpx;
}

.cloud-action-btn {
  display: flex;
  align-items: center;
  padding: 20rpx 8rpx;
  border-radius: 8rpx;
}

.cloud-action-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.cloud-action-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.cloud-action-value {
  font-size: 26rpx;
  color: var(--accent-primary);
  font-weight: 600;
  margin-right: 8rpx;
}

.cloud-action-btn::after {
  content: '›';
  font-size: 32rpx;
  color: var(--text-secondary);
}

/* 免责声明弹窗 */
.cloud-disclaimer-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--card-bg);
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 1001;
}

.cloud-disclaimer-modal-show {
  transform: translateY(0);
}

.cloud-disclaimer-header {
  padding: 32rpx 32rpx 20rpx;
  text-align: center;
  border-bottom: 1rpx solid var(--border-color);
}

.cloud-disclaimer-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.cloud-disclaimer-content {
  max-height: 60vh;
  padding: 24rpx 32rpx;
  overflow-y: auto;
}

.cloud-disclaimer-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.8;
  white-space: pre-line;
}

.cloud-disclaimer-footer {
  display: flex;
  gap: 24rpx;
  padding: 20rpx 32rpx 32rpx;
}

.cloud-disclaimer-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.cloud-disclaimer-cancel {
  background: var(--lcd-bg);
  border: 1rpx solid var(--border-color);
  color: var(--text-secondary);
}

.cloud-disclaimer-agree {
  background: var(--accent-primary);
  color: #fff;
}

/* 版本号标签 */
.cell-version {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-left: auto;
  margin-right: 16rpx;
}

/* 更新日志弹窗 */
.update-log-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--card-bg);
  border-radius: 32rpx 32rpx 0 0;
  max-height: 70vh;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 1001;
  display: flex;
  flex-direction: column;
}

.update-log-modal-show {
  transform: translateY(0);
}

.update-log-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid var(--border-color);
  flex-shrink: 0;
}

.update-log-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.update-log-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-secondary);
  border-radius: 50%;
  background: var(--bg-primary);
}

.update-log-content {
  flex: 1;
  padding: 24rpx 32rpx;
  max-height: 50vh;
}

.update-log-item {
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.update-log-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.update-log-version {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.version-tag {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--accent-primary);
  background: var(--lcd-bg);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.version-date {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.update-log-title-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.update-log-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.update-log-line {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.update-log-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
  border-top: 1rpx solid var(--border-color);
}

.update-log-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--accent-primary);
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}
