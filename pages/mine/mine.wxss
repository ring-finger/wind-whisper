/* 与 app.wxss 令牌一致：--bg-main / --card-bg / --text-* / --primary-* */

.mine-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
  background: var(--bg-main);
}

.mine-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 20rpx;
  overflow: hidden;
}

/* 头像 + 昵称 */
.profile-row {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  gap: 28rpx;
}

.avatar-stack {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
  flex-grow: 0;
  border-radius: 50%;
  overflow: hidden;
  background: var(--bg-main);
  box-shadow: 0 0 0 2rpx var(--primary-soft);
}

.avatar-face {
  position: absolute;
  left: 0;
  top: 0;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  pointer-events: none;
  background: var(--bg-main);
}

.user-avatar-img {
  width: 120rpx;
  height: 120rpx;
  display: block;
}

.user-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--lcd-bg);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.avatar-tap {
  position: absolute;
  left: 0;
  top: 0;
  width: 120rpx;
  height: 120rpx;
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 50%;
  background: transparent;
  line-height: 0;
  min-height: 0;
  box-sizing: border-box;
}

.avatar-tap::after {
  border: none;
}

.nickname-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  padding: 0 20rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-main);
  background: var(--card-bg);
  border-radius: 12rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
}

/* 分组列表 */
.mine-group .cell {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 100rpx;
  padding: 20rpx 28rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.mine-group .cell:last-child {
  border-bottom: none;
}

.cell-primary-block {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  max-width: 46%;
}

.cell-label-strong {
  font-weight: 600;
  color: var(--text-main);
}

.cell-value-callsign {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: var(--primary-color);
}

.cell-value-count {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
}

.cell-hover {
  opacity: 0.88;
}

.cell-label {
  flex-shrink: 0;
  font-size: 30rpx;
  color: var(--text-main);
  font-weight: 500;
}

.cell-label-full {
  flex: 1;
}

.cell-value {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: var(--text-main);
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cell-chevron {
  flex-shrink: 0;
  font-size: 32rpx;
  color: var(--text-sec);
  font-weight: 300;
  line-height: 1;
}

.cell-chevron-placeholder {
  opacity: 0;
  pointer-events: none;
}

.easter-egg-message {
  position: fixed;
  top: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  text-align: center;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  background: rgba(0, 0, 0, 0.82);
  border-radius: 40rpx;
  color: #fff;
  z-index: 9999;
  white-space: nowrap;
  max-width: 90%;
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* 联系作者展开区：与全局令牌一致，层次参考稿 */
.author-card {
  padding: 32rpx 28rpx 28rpx;
}

.author-header {
  display: flex;
  align-items: baseline;
  justify-content: center;
  flex-wrap: wrap;
  gap: 8rpx 12rpx;
  margin-bottom: 28rpx;
}

.author-label {
  font-size: 28rpx;
  color: var(--text-sec);
  font-weight: 500;
}

.author-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--primary-color);
  letter-spacing: 2rpx;
}

.author-action {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  padding: 22rpx 56rpx 22rpx 28rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  background: var(--lcd-bg);
  border: 1rpx solid rgba(0, 122, 255, 0.12);
  box-sizing: border-box;
}

.author-action-text {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.author-action-chevron {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  font-weight: 300;
  color: var(--primary-color);
  line-height: 1;
}

.author-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-sec);
  line-height: 1.45;
  padding: 0 8rpx;
}
