page {
  --primary-color: #007aff;
  --bg-main: #f5f7fa;
  --card-bg: #ffffff;
  --text-main: #1c1c1e;
  --text-sec: #8e8e93;
  --accent-orange: #ff9500;
  --primary-soft: rgba(0, 122, 255, 0.12);
  --lcd-bg: #e8f2ff;

  background-color: var(--bg-main);
  color: var(--text-main);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
}

.font-mono {
  font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
}

.button-hover {
  opacity: 0.82;
  transform: scale(0.98);
}

.container {
  padding: 24rpx;
  box-sizing: border-box;
}

.float-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.form-item {
  background: var(--card-bg);
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.form-label {
  font-size: 24rpx;
  color: var(--text-sec);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--text-main);
  box-sizing: border-box;
  text-align: left;
  line-height: 76rpx;
  background: var(--card-bg);
}

.picker-input {
  text-align: center;
}

.form-input:focus {
  border-color: var(--primary-color);
}

.time-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.date-time-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.date-section {
  flex: 1;
  min-width: 0;
}

.time-section {
  flex: 1;
  min-width: 0;
}

.time-type-toggle {
  padding: 10rpx 16rpx;
  background: var(--bg-main);
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-main);
}

.time-type-toggle:active {
  opacity: 0.85;
}

.time-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.refresh-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-main);
  border-radius: 12rpx;
  font-size: 30rpx;
  color: var(--primary-color);
}

.refresh-btn:active {
  opacity: 0.85;
}

.weather-icons {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.weather-icon {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-main);
  border-radius: 50%;
  border: none;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.weather-icon.selected {
  background: var(--primary-soft);
  box-shadow: 0 0 0 3rpx var(--primary-color);
}

.mode-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.mode-tag {
  padding: 14rpx 28rpx;
  background: rgba(142, 142, 147, 0.15);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-main);
  border: none;
  transition: all 0.2s ease;
}

.mode-tag.selected {
  background: var(--primary-color);
  color: #fff;
}

.rst-inputs {
  display: flex;
  gap: 16rpx;
}

.rst-item {
  flex: 1;
}

.rst-label {
  font-size: 22rpx;
  color: var(--text-sec);
  margin-bottom: 10rpx;
  text-align: center;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: var(--primary-color);
  color: #fff;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 32rpx;
  border: none;
  box-shadow: 0 8rpx 28rpx rgba(0, 122, 255, 0.35);
  text-align: center;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  opacity: 0.92;
}

.log-item {
  background: var(--card-bg);
  margin-bottom: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.log-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.log-callsign {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.log-date {
  font-size: 24rpx;
  color: var(--text-sec);
}

.log-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  font-size: 26rpx;
  color: var(--text-sec);
}

.log-detail-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: var(--text-sec);
  font-size: 28rpx;
}
