/* 默认使用无线电主题 */
page {
  /* 无线电主题 - Radio Theme */
  --bg-primary: #F4F7FA;
  --bg-main: #F4F7FA;
  --card-bg: #FFFFFF;
  --border-color: #D4E0ED;
  --shadow-color: rgba(58, 85, 130, 0.1);
  --text-primary: #1A2B42;
  --text-main: #1A2B42;
  --text-secondary: #5B697F;
  --text-sec: #5B697F;
  --text-placeholder: #8E99A8;
  --text-inverse: #FFFFFF;
  --color-log: #E6F0F8;
  --color-decode: #E8F5E9;
  --color-qso: #FFF3E0;
  --color-profile: #E8EAF6;
  --accent-primary: #2C5C97;
  --primary-color: #2C5C97;
  --primary-soft: rgba(44, 92, 151, 0.12);
  --accent-active: #388E3C;
  --accent-secondary: #D84315;
  --accent-orange: #D84315;
  --lcd-bg: #E8EEF4;
  --success: #388E3C;
  --warning: #F57C00;
  --error: #D32F2F;
  --info: #2C5C97;
  /* RGB 格式变量（用于半透明叠加层） */
  --text-primary-rgb: 26, 43, 66;
  --text-inverse-rgb: 255, 255, 255;
  --accent-primary-rgb: 44, 92, 151;
  --error-rgb: 211, 47, 47;
  /* 渐变辅助色 - 第1主题 */
  --gradient-accent1: #A55555;
  --gradient-accent2: #6B9A5F;
  --gradient-accent3: #A85540;
  /* 操作按钮颜色（用于半透明叠加层） */
  --action-blue-rgb: 59, 130, 246;
  --action-red-rgb: 220, 38, 38;
  --info-soft: rgba(107, 142, 174, 0.1);
  /* 导航栏背景色 - 统一浅色系 */
  --nav-bg: #F9F7F4;           /* 超浅暖灰背景 */
  --nav-text: #443D33;         /* 中性文字色 */
  --nav-text-active: #2C5C97;  /* 激活色 */
  --nav-border: #EAE5DD;       /* 浅边框 */
  /* 柱状图填充色 - 浅色系 */
  --bar-gradient-start: #A8D5EF;
  --bar-gradient-end: #CCE5FF;

  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
}

/* 主题包装器 - 用于主题切换 */
.theme-wrapper {
  min-height: 100vh;
  background-color: var(--bg-primary);
  color: var(--text-primary);
}

/* 奶油莫兰迪主题 - 应用于包装器 */
.theme-wrapper.theme-morandi {
  --bg-primary: #F5F0E6;
  --bg-main: #F5F0E6;
  --card-bg: #F8F2E9;
  --border-color: #E8DED0;
  --shadow-color: rgba(180, 169, 150, 0.15);
  --text-primary: #3A3226;
  --text-main: #3A3226;
  --text-secondary: #7A6F5F;
  --text-sec: #7A6F5F;
  --text-placeholder: #B5A996;
  --text-inverse: #F8F2E9;
  --color-log: #F2E3C6;
  --color-decode: #DDE8D2;
  --color-qso: #F0D8C8;
  --color-profile: #E8DDCC;
  --accent-primary: #C4643E;
  --primary-color: #C4643E;
  --primary-soft: rgba(196, 100, 62, 0.12);
  --accent-active: #85A877;
  --accent-secondary: #6B8EAE;
  --accent-orange: #C4643E;
  --lcd-bg: #EDE6DA;
  --success: #85A877;
  --warning: #D4A373;
  --error: #BB6464;
  --info: #6B8EAE;
  /* RGB 格式变量（用于半透明叠加层） */
  --text-primary-rgb: 58, 50, 38;
  --text-inverse-rgb: 248, 242, 233;
  --accent-primary-rgb: 196, 100, 62;
  --error-rgb: 187, 100, 100;
  /* 渐变辅助色 - 第2主题（莫兰迪） */
  --gradient-accent1: #A55555;
  --gradient-accent2: #6B9A5F;
  --gradient-accent3: #A85540;
  /* 操作按钮颜色（用于半透明叠加层） */
  --action-blue-rgb: 107, 142, 174;
  --action-red-rgb: 187, 100, 100;
  --info-soft: rgba(147, 142, 130, 0.1);
  /* 导航栏背景色 - 统一使用浅色系，不随主题变化 */
  /* 柱状图填充色 - 暖浅色系 */
  --bar-gradient-start: #E8C8A0;
  --bar-gradient-end: #F0DCC0;

  background-color: var(--bg-primary);
  color: var(--text-primary);
}



/* ============================================
   全局基础样式
   ============================================ */

.font-mono {
  font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
}

.button-hover {
  opacity: 0.82;
  transform: scale(0.98);
}

.container {
  padding: 24rpx;
  box-sizing: border-box;
}

.float-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 24rpx var(--shadow-color);
  box-sizing: border-box;
}

.form-item {
  background: var(--card-bg);
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 24rpx var(--shadow-color);
  box-sizing: border-box;
}

.form-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  text-align: left;
  line-height: 76rpx;
  background: var(--card-bg);
}

.picker-input {
  text-align: center;
}

.form-input:focus {
  border-color: var(--accent-primary);
}

.time-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.date-time-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.date-section {
  flex: 1;
  min-width: 0;
}

.time-section {
  flex: 1;
  min-width: 0;
}

.time-type-toggle {
  padding: 10rpx 16rpx;
  background: var(--bg-primary);
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.time-type-toggle:active {
  opacity: 0.85;
}

.time-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.refresh-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-primary);
  border-radius: 12rpx;
  font-size: 30rpx;
  color: var(--accent-primary);
}

.refresh-btn:active {
  opacity: 0.85;
}

.weather-icons {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.weather-icon {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-primary);
  border-radius: 50%;
  border: none;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.weather-icon.selected {
  background: var(--primary-soft);
  box-shadow: 0 0 0 3rpx var(--accent-primary);
}

.mode-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.mode-tag {
  padding: 14rpx 28rpx;
  background: rgba(122, 111, 95, 0.12);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  border: none;
  transition: all 0.2s ease;
}

.mode-tag.selected {
  background: var(--accent-primary);
  color: var(--text-inverse);
}

.rst-inputs {
  display: flex;
  gap: 16rpx;
}

.rst-item {
  flex: 1;
}

.rst-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
  text-align: center;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: var(--accent-primary);
  color: var(--text-inverse);
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 32rpx;
  border: none;
  box-shadow: 0 8rpx 28rpx rgba(var(--accent-primary-rgb), 0.35);
  text-align: center;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  opacity: 0.92;
}

.log-item {
  background: var(--card-bg);
  margin-bottom: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx var(--shadow-color);
}

.log-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.log-callsign {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--accent-primary);
}

.log-date {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.detail {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: var(--text-secondary);
  font-size: 28rpx;
}
