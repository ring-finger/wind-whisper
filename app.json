{
  "pages": [
    "pages/index/index",
    "pages/mine/mine",
    "pages/web-view/web-view"
  ],
  "window": {
    "backgroundTextStyle": "dark",
    "navigationBarBackgroundColor": "#F9F7F4",
    "navigationBarTitleText": "风语纪",
    "navigationBarTextStyle": "black",
    "backgroundColor": "#F5F7FA"
  },
  "style": "v2",
  "lazyCodeLoading": "requiredComponents",
  "sitemapLocation": "sitemap.json",
  "subpackages": [
    {
      "root": "pages/sstv",
      "pages": [
        "sstv"
      ],
      "independent": true
    },
    {
      "root": "pages/logs",
      "pages": [
        "logs",
        "log-detail/log-detail"
      ]
    }
  ],
  "preloadRule": {
    "pages/index/index": {
      "packages": [
        "pages/logs"
      ],
      "network": "all"
    }
  }
}
